<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    
    <!-- Modern Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["QIN-Production-Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <script>
        (function() {
            var theme = localStorage.getItem('qin_theme') || 'dark';
            var fontSize = localStorage.getItem('qin_fontsize') || '100';
            document.documentElement.setAttribute('data-theme', theme);
            document.documentElement.style.setProperty('--user-font-scale', fontSize + '%');
        })();
    </script>
    <HeadOutlet @rendermode="new InteractiveServerRenderMode(prerender: false)" />
</head>

<body data-theme="dark">
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        window.downloadFileFromStream = async (fileName, contentStreamReference) => {
            const arrayBuffer = await contentStreamReference.arrayBuffer();
            const blob = new Blob([arrayBuffer]);
            const url = URL.createObjectURL(blob);
            const anchorElement = document.createElement('a');
            anchorElement.href = url;
            anchorElement.download = fileName ?? '';
            anchorElement.click();
            anchorElement.remove();
            URL.revokeObjectURL(url);
        };

        window.updateClientSettings = (theme, fontSize) => {
            localStorage.setItem('qin_theme', theme);
            localStorage.setItem('qin_fontsize', fontSize);
            document.documentElement.setAttribute('data-theme', theme);
            document.documentElement.style.setProperty('--user-font-scale', fontSize + '%');
        };

        window.resetClientSettings = () => {
            localStorage.removeItem('qin_theme');
            localStorage.removeItem('qin_fontsize');
            document.documentElement.setAttribute('data-theme', 'dark');
            document.documentElement.style.setProperty('--user-font-scale', '100%');
        };

        window.makeTableResizable = function(tableId) {
            const table = document.getElementById(tableId);
            if (!table) return;
            
            if (table.classList.contains('resizable-initialized')) return;
            table.classList.add('resizable-initialized');

            const cols = table.querySelectorAll('th');
            [].forEach.call(cols, function (col) {
                const resizer = document.createElement('div');
                resizer.classList.add('table-resizer-handle');
                col.appendChild(resizer);
                
                let x = 0;
                let w = 0;

                const mouseDownHandler = function (e) {
                    x = e.clientX;
                    const styles = window.getComputedStyle(col);
                    w = parseInt(styles.width, 10);
                    
                    document.addEventListener('mousemove', mouseMoveHandler);
                    document.addEventListener('mouseup', mouseUpHandler);
                    resizer.classList.add('resizing');
                    e.stopPropagation();
                    e.preventDefault();
                };

                const mouseMoveHandler = function (e) {
                    const dx = e.clientX - x;
                    const nextWidth = Math.max(70, w + dx);
                    col.style.width = nextWidth + 'px';
                    col.style.minWidth = nextWidth + 'px';
                };

                const mouseUpHandler = function () {
                    document.removeEventListener('mousemove', mouseMoveHandler);
                    document.removeEventListener('mouseup', mouseUpHandler);
                    resizer.classList.remove('resizing');
                };

                resizer.addEventListener('mousedown', mouseDownHandler);
            });
        };

        window.scrollToBottom = (elementId) => {
            const element = document.getElementById(elementId);
            if (element) {
                element.scrollTop = element.scrollHeight;
            }
        };

        window.scrollToId = (id) => {
            const element = document.getElementById(id);
            if (element) {
                requestAnimationFrame(() => {
                    requestAnimationFrame(() => {
                        element.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    });
                });
            }
        };

        window.scrollToChildInContainer = (containerId, childId) => {
            const container = document.getElementById(containerId);
            const child = document.getElementById(childId);
            if (!container || !child) return;

            const getRelativeTop = (element, ancestor) => {
                let top = 0;
                let current = element;

                while (current && current !== ancestor) {
                    top += current.offsetTop;
                    current = current.offsetParent;
                }

                return top;
            };

            requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                    const targetTop = Math.max(0, getRelativeTop(child, container) - 12);
                    container.scrollTo({ top: targetTop, behavior: 'smooth' });
                });
            });
        };

        window.printHtmlDocument = async (html) => {
            if (!html) {
                throw new Error('Keine Druckansicht erhalten.');
            }

            await new Promise((resolve, reject) => {
                try {
                    const iframe = document.createElement('iframe');
                    iframe.style.position = 'fixed';
                    iframe.style.width = '0';
                    iframe.style.height = '0';
                    iframe.style.border = '0';
                    iframe.style.opacity = '0';
                    iframe.style.pointerEvents = 'none';
                    iframe.setAttribute('aria-hidden', 'true');
                    document.body.appendChild(iframe);

                    let completed = false;

                    const finish = () => {
                        if (completed) return;
                        completed = true;
                        setTimeout(() => iframe.remove(), 500);
                        resolve();
                    };

                    const printWindow = iframe.contentWindow;
                    const printDocument = printWindow?.document;

                    if (!printWindow || !printDocument) {
                        iframe.remove();
                        reject(new Error('Die Druckansicht konnte nicht erstellt werden.'));
                        return;
                    }

                    const triggerPrint = () => {
                        try {
                            printWindow.focus();
                            printWindow.print();
                            setTimeout(finish, 1500);
                        } catch (error) {
                            iframe.remove();
                            reject(error);
                        }
                    };

                    printWindow.addEventListener('afterprint', finish, { once: true });
                    iframe.addEventListener('load', () => setTimeout(triggerPrint, 150), { once: true });

                    printDocument.open();
                    printDocument.write(html);
                    printDocument.close();
                } catch (error) {
                    reject(error);
                }
            });
        };
    </script>
    <script src="_content/Blazor-ApexCharts/js/apex-charts.min.js"></script>
    <script src="_content/Blazor-ApexCharts/js/blazor-apex-charts.js"></script>
</body>

</html>
