@using Microsoft.AspNetCore.Components.Authorization
@using QIN_Production_Web.Data
@implements IDisposable
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject NachrichtenService MessageService
@inject AlertService AlertService

<div class="@($"brand-section {(IsCollapsed ? "collapsed" : "justify-content-between")}")">
    <div class="d-flex align-items-center gap-3">
        <div class="brand-logo" title="QIN Tool">
            <i class="fa-solid fa-industry"></i>
        </div>
        @if (!IsCollapsed)
        {
            <div class="brand-text">
                <h3>QIN-FORM</h3>
                <span>v3.1.1 Web</span>
            </div>
        }
    </div>
    @if (!IsCollapsed)
    {
        <button class="btn btn-link text-secondary p-0" title="Navigation einklappen" @onclick="ToggleMenu">
            <i class="fa-solid fa-bars fs-5"></i>
        </button>
    }
    else
    {
        <button class="btn btn-link text-secondary p-0 mt-3" title="Navigation ausklappen" @onclick="ToggleMenu">
            <i class="fa-solid fa-bars fs-5"></i>
        </button>
    }
</div>

<nav class="nav-container">
    <div class="nav-section">
        <NavLink class="@($"nav-item {(IsCollapsed ? "collapsed-item" : "")}")" href="" Match="NavLinkMatch.All" title="Dashboard">
            <i class="fa-solid fa-home nav-icon"></i>
            @if(!IsCollapsed) { <span>Dashboard</span> }
        </NavLink>
        
        <hr style="border-color: var(--border-color); margin: 12px 14px;" />
        
        <!-- Quick Actions -->
        <button class="@($"nav-item w-100 text-start border-0 {(IsCollapsed ? "collapsed-item px-0" : "px-3")} mb-3")" 
                title="Zeiterfassung Starten" 
                style="background: rgba(59, 130, 246, 0.15); border-left: 3px solid var(--accent-primary) !important; color: var(--text-primary) !important;" 
                @onclick='() => NavigationManager.NavigateTo("/verwaltung/zeiterfassung")'>
            <i class="fa-solid fa-clock nav-icon text-info"></i>
            @if(!IsCollapsed) { <span class="fw-bold">Zeiterfassung</span> }
        </button>

        <!-- Fertigung Group -->
        <div class="nav-group">
            <div class="@($"nav-item has-children {(IsCollapsed ? "collapsed-item" : "")}")" @onclick="ToggleFertigung" title="Fertigung">
                <div class="group-title-wrapper">
                    <i class="fa-solid fa-bars-progress nav-icon"></i>
                    @if(!IsCollapsed) { <span>Fertigung</span> }
                </div>
                @if (!IsCollapsed)
                {
                    <i class="fa-solid fa-chevron-@(IsFertigungOpen ? "down" : "right") chevron"></i>
                }
            </div>
            
            @if (IsFertigungOpen && !IsCollapsed)
            {
                <div class="nav-submenu">
                    <NavLink class="sub-item" href="fertigung/wareneingang">Wareneingang</NavLink>
                    <NavLink class="sub-item" href="fertigung/kiefel">Kiefel & Parco</NavLink>
                    <NavLink class="sub-item" href="fertigung/panther">Panther</NavLink>
                    <NavLink class="sub-item" href="fertigung/uv-haerten">UV-Härten</NavLink>
                    <NavLink class="sub-item" href="fertigung/stanzen">Stanzen u. Fräsen</NavLink>
                    <NavLink class="sub-item" href="fertigung/endkontrolle">Endkontrolle</NavLink>
                </div>
            }
        </div>

        <!-- Verwaltung Group -->
        <AuthorizeView Roles="Admin, Verwaltung">
            <Authorized Context="AuthContext">
                <div class="nav-group">
                    <div class="@($"nav-item has-children {(IsCollapsed ? "collapsed-item" : "")}")" @onclick="ToggleVerwaltung" title="Verwaltung">
                        <div class="group-title-wrapper">
                            <i class="fa-solid fa-user-tie nav-icon text-warning"></i>
                            @if(!IsCollapsed) { <span>Verwaltung</span> }
                        </div>
                        @if (!IsCollapsed)
                        {
                            <i class="fa-solid fa-chevron-@(IsVerwaltungOpen ? "down" : "right") chevron"></i>
                        }
                    </div>
                    
                    @if (IsVerwaltungOpen && !IsCollapsed)
                    {
                        <div class="nav-submenu">
                            <NavLink class="sub-item" href="verwaltung/fehleranalyse">Fehleranalyse</NavLink>
                            <NavLink class="sub-item" href="verwaltung/chargenanalyse">Chargenanalyse</NavLink>
                            <!-- <NavLink class="sub-item" href="verwaltung/barcode">Barcode-Profile</NavLink> -->
                            <NavLink class="sub-item" href="verwaltung/auftraege">Fertigungsaufträge</NavLink>
                            <NavLink class="sub-item" href="verwaltung/wareneingang">Wareneingang</NavLink>
                            <NavLink class="sub-item" href="verwaltung/layout">Produktionslayout</NavLink>
                            <NavLink class="sub-item text-info fw-bold" href="verwaltung/aktivitaeten"><i class="fa-solid fa-list-check me-1"></i> Aktivitätenprotokoll</NavLink>
                        </div>
                    }
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</nav>

<div class="@($"bottom-nav {(IsCollapsed ? "collapsed-nav" : "")}")">
    <!-- Notification Dock -->
    <div class="@($"d-flex mb-3 {(IsCollapsed ? "flex-column align-items-center gap-3" : "justify-content-around px-2")}")">
        <NavLink class="btn position-relative p-2" href="nachrichten" title="Systemnachrichten" style="border-radius: 12px; background: var(--border-color); color: var(--text-secondary); transition: all 0.2s;">
            <i class="fa-solid fa-envelope fs-5"></i>
            @if (UnreadCount > 0)
            {
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shadow-sm border border-dark" style="font-size: 0.6rem;">@UnreadCount</span>
            }
        </NavLink>
        
        <button class="btn position-relative p-2" title="Benachrichtigungen" style="border-radius: 12px; background: var(--border-color); color: var(--text-secondary); transition: all 0.2s;" @onclick="OpenNavAlerts">
            <i class="fa-solid fa-bell fs-5"></i>
            @if (AlertCount > 0)
            {
                <span class="position-absolute top-0 start-100 translate-middle p-1 bg-warning border border-dark rounded-circle shadow-sm"></span>
            }
        </button>
    </div>

    <AuthorizeView>
        <Authorized>
            <div class="@($"nav-item user-profile mb-2 {(IsCollapsed ? "collapsed-item" : "")}")" title="@context.User.Identity?.Name">
                <i class="fa-solid fa-circle-user nav-icon text-info fs-4"></i>
                @if(!IsCollapsed) { 
                    <div class="user-info ms-2" style="line-height: 1.2;">
                        <span class="d-block fw-bold text-white" style="font-size: 0.85rem;">@context.User.Identity?.Name</span>
                        <span class="d-block text-secondary" style="font-size: 0.70rem; text-transform: uppercase;">@context.User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value</span>
                    </div>
                }
            </div>
            
            <a class="@($"nav-item text-danger border-top border-secondary pt-3 {(IsCollapsed ? "collapsed-item" : "")}")" href="/api/auth/logout" target="_top" style="cursor: pointer;" title="Abmelden">
                <i class="fa-solid fa-right-from-bracket nav-icon"></i>
                @if(!IsCollapsed) { <span>Abmelden</span> }
            </a>
        </Authorized>
    </AuthorizeView>

    <NavLink class="@($"nav-item {(IsCollapsed ? "collapsed-item" : "")}")" href="einstellungen" title="Einstellungen">
        <i class="fa-solid fa-gear nav-icon"></i>
        @if(!IsCollapsed) { <span>Einstellungen</span> }
    </NavLink>
</div>

<!-- Nav Alerts Modal -->
@if (showNavAlerts)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content bg-dark text-white border-secondary shadow-lg">
                <div class="modal-header border-bottom border-secondary">
                    <h5 class="modal-title text-primary fw-bold">
                        <i class="fa-solid fa-bullhorn me-2"></i> Aktuelle Ankündigungen
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseNavAlerts"></button>
                </div>
                <div class="modal-body p-0" style="max-height: 60vh; overflow-y: auto;">
                    <div class="list-group list-group-flush border-0">
                        @if (navAlerts.Count == 0)
                        {
                            <div class="p-4 text-center text-secondary">
                                <i class="fa-solid fa-check-circle fs-2 mb-2"></i><br/>
                                Keine Ankündigungen vorhanden.
                            </div>
                        }
                        else
                        {
                            @foreach (var alert in navAlerts)
                            {
                                <div class="list-group-item border-bottom border-secondary m-0 rounded-0" style="background: rgba(30,30,30,0.5);">
                                    <strong class="@(!alert.IsRead ? "text-white" : "text-secondary") fs-5 d-block mb-2">
                                        @if (!alert.IsRead) { <span class="badge bg-blue me-2 shadow-sm rounded-pill" style="font-size: 0.70rem;">Neu</span> }
                                        @alert.Title
                                    </strong>
                                    <p class="text-secondary mb-3" style="white-space: pre-wrap; line-height: 1.5;">@alert.Message</p>
                                    <div class="text-secondary small d-flex justify-content-between border-top border-dark pt-2">
                                        <span><i class="fa-solid fa-user-pen me-1"></i> @alert.CreatedBy</span>
                                        <span><i class="fa-regular fa-clock me-1"></i> @alert.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-3">
                    <button type="button" class="btn btn-secondary w-100 fw-bold" @onclick="CloseNavAlerts">Schließen</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsCollapsed { get; set; }
    
    [Parameter]
    public EventCallback OnToggle { get; set; }

    private bool IsFertigungOpen = true;
    private bool IsVerwaltungOpen = false;

    private int UnreadCount = 0;
    private int AlertCount = 0;
    private bool showNavAlerts = false;
    private List<SystemAlert> navAlerts = new();
    
    private System.Threading.Timer? _pollingTimer;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var role = authState.User?.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value;

        if (role == "Admin" || role == "Verwaltung")
        {
            IsFertigungOpen = false;
            IsVerwaltungOpen = true;
        }

        MessageService.OnUnreadCountChanged += HandleUnreadCountChanged;
        
        await LoadUnreadCount();
        await LoadAlerts();
        
        // Background polling every 5 seconds to catch cross-browser messages
        _pollingTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadUnreadCount();
                StateHasChanged();
            });
        }, null, 5000, 5000); 
    }

    private async void HandleUnreadCountChanged()
    {
        await InvokeAsync(async () =>
        {
            await LoadUnreadCount();
            StateHasChanged();
        });
    }

    private async Task LoadUnreadCount()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        string user = authState.User?.Identity?.Name ?? string.Empty;
        if (!string.IsNullOrEmpty(user))
        {
            UnreadCount = await MessageService.GetTotalUnreadCountAsync(user);
        }
    }

    private async Task LoadAlerts()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        string userId = authState.User?.Claims.FirstOrDefault(c => c.Type == "UserId")?.Value ?? string.Empty;
        if (!string.IsNullOrEmpty(userId))
        {
            navAlerts = await AlertService.GetRecentAlertsAsync(userId);
            AlertCount = navAlerts.Count(a => !a.IsRead);
        }
    }

    private async Task OpenNavAlerts()
    {
        showNavAlerts = true;
        
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        string userId = authState.User?.Claims.FirstOrDefault(c => c.Type == "UserId")?.Value ?? string.Empty;
        
        if (!string.IsNullOrEmpty(userId))
        {
            var unreadAlerts = navAlerts.Where(a => !a.IsRead).ToList();
            foreach (var alert in unreadAlerts)
            {
                alert.IsRead = true;
                await AlertService.MarkAlertAsReadAsync(alert.AlertID, userId);
            }
            AlertCount = 0;
        }
    }

    private void CloseNavAlerts()
    {
        showNavAlerts = false;
    }

    private void ToggleFertigung() {
        if(!IsCollapsed) IsFertigungOpen = !IsFertigungOpen;
    }
    private void ToggleVerwaltung() {
        if(!IsCollapsed) IsVerwaltungOpen = !IsVerwaltungOpen;
    }

    private async Task ToggleMenu()
    {
        if (OnToggle.HasDelegate)
        {
            await OnToggle.InvokeAsync();
        }
    }

    public void Dispose()
    {
        MessageService.OnUnreadCountChanged -= HandleUnreadCountChanged;
        _pollingTimer?.Dispose();
    }
}

