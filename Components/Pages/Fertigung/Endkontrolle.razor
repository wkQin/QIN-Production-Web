@page "/fertigung/endkontrolle"
@using QIN_Production_Web.Data
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject UserService UserService
@inject IJSRuntime JS

<PageTitle>Endkontrolle Erfassung - Sauberraum</PageTitle>

<div id="endkontrollePageDragSurface" class="endkontrolle-page">
    <div class="dashboard-header end-header mb-4 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <h2 class="mb-0">Endkontrolle Erfassung</h2>
                <span class="badge end-badge-room">SAUBERRAUM</span>
            </div>
            <p class="text-secondary mt-2 mb-0">Fehlersammelkarte schnell und verst&auml;ndlich erfassen oder vorhandene Eintr&auml;ge &auml;ndern.</p>
        </div>

        @if (IsEditMode)
        {
            <div class="edit-mode-pill">
                <div class="fw-bold">Bearbeitungsmodus aktiv</div>
                <div class="small text-secondary">Sie bearbeiten gerade Eintrag ID @NeuerEintrag.ID.</div>
                <button class="btn btn-light btn-sm mt-2" @onclick="ResetForm">Neue Erfassung starten</button>
            </div>
        }
    </div>

    <div class="end-hint-card mb-4">
        <div class="end-hint-title">So funktioniert es</div>
        @if (IsEditMode)
        {
            <div class="end-hint-text">
                1. Unten ist der ausgew&auml;hlte Eintrag markiert.
                2. Oben Werte anpassen.
                3. Auf <strong>Aktualisieren</strong> klicken.
            </div>
        }
        else
        {
            <div class="end-hint-text">
                1. F&uuml;r neuen Eintrag Formular oben ausf&uuml;llen und <strong>Speichern</strong> klicken.
                2. F&uuml;r &Auml;nderungen unten auf <strong>Bearbeiten</strong> klicken.
            </div>
        }
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-4">
            <div class="content-card end-card h-100">
                <div class="card-header-flex end-card-header">
                    <h4>Auftragsdaten</h4>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label end-label">Charge</label>
                        <input type="text" class="form-control dark-input end-input" @bind="NeuerEintrag.Charge" placeholder="Charge eingeben" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label end-label">FA-Nummer</label>
                        <input type="text" class="form-control dark-input end-input" @bind="NeuerEintrag.FANr" placeholder="FA-Nummer eingeben" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label end-label">Kunde</label>
                        <select class="form-select dark-input end-input" value="@NeuerEintrag.Kunde" @onchange="OnKundeChanged">
                            <option value="">Bitte ausw&auml;hlen</option>
                            @foreach (var k in Kunden)
                            {
                                <option value="@k.Name" style="@(k.IsActive ? "" : "color: var(--color15); font-style: italic;")">
                                    @k.Name @(k.IsActive ? "" : "(Inaktiv)")
                                </option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label end-label">Projekt</label>
                        <select class="form-select dark-input end-input" value="@NeuerEintrag.Projekt" @onchange="OnProjektChanged">
                            <option value="">Bitte ausw&auml;hlen</option>
                            @foreach (var p in Projekte)
                            {
                                <option value="@p">@p</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label end-label">Artikel</label>
                        <select class="form-select dark-input end-input" @bind="NeuerEintrag.Artikel">
                            <option value="">Bitte ausw&auml;hlen</option>
                            @foreach (var a in ArtikelListe)
                            {
                                <option value="@a">@a</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label end-label">Dekor</label>
                        <select class="form-select dark-input end-input" @bind="NeuerEintrag.Dekor">
                            <option value="">Bitte ausw&auml;hlen</option>
                            @foreach (var d in DekorListe)
                            {
                                <option value="@d">@d</option>
                            }
                        </select>
                    </div>
                    <div class="mb-0">
                        <label class="form-label end-label">Bemerkung</label>
                        <input type="text" class="form-control dark-input end-input" @bind="NeuerEintrag.Bemerkung" placeholder="Optionaler Hinweis" />
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="content-card end-card h-100 d-flex flex-column">
                <div class="card-header-flex end-card-header">
                    <h4>Fehlersammelkarte</h4>
                    <span class="end-section-note">Bitte alle Werte sorgf&auml;ltig pr&uuml;fen</span>
                </div>

                <div class="card-body">
                    @if (IsEditMode)
                    {
                        <div class="edit-banner mb-4">
                            <div class="fw-bold">Eintrag wird bearbeitet</div>
                            <div>Nach der Anpassung bitte unten auf <strong>Aktualisieren</strong> klicken.</div>
                        </div>
                    }

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="form-label end-label">Datum</label>
                            <input type="date" class="form-control dark-input end-input end-input-lg" @bind="NeuerEintrag.Datum" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label end-label text-success">Gutteile</label>
                            <input type="number" class="form-control dark-input end-input end-input-lg end-good-input" @bind="NeuerEintrag.Gutteile" />
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="error-box">
                                <h5>Externe Fehler</h5>
                                <div class="error-row">
                                    <span>Fusseln</span>
                                    <input type="number" class="form-control text-center dark-input end-mini-input" @bind="NeuerEintrag.Fusseln" />
                                </div>
                                <div class="error-row">
                                    <span>Nadelstiche</span>
                                    <input type="number" class="form-control text-center dark-input end-mini-input" @bind="NeuerEintrag.Nadelstiche" />
                                </div>
                                <div class="error-row">
                                    <span>Pickel</span>
                                    <input type="number" class="form-control text-center dark-input end-mini-input" @bind="NeuerEintrag.Pickel" />
                                </div>
                                <div class="error-row">
                                    <span>Dekorfehler</span>
                                    <input type="number" class="form-control text-center dark-input end-mini-input" @bind="NeuerEintrag.Dekorfehler" />
                                </div>
                                <div class="error-row">
                                    <span>Farbfehler</span>
                                    <input type="number" class="form-control text-center dark-input end-mini-input" @bind="NeuerEintrag.Farbfehler" />
                                </div>
                                <div class="error-row">
                                    <span>Flecken</span>
                                    <input type="number" class="form-control text-center dark-input end-mini-input" @bind="NeuerEintrag.Flecken" />
                                </div>
                                <div class="error-row">
                                    <span>Nebel</span>
                                    <input type="number" class="form-control text-center dark-input end-mini-input" @bind="NeuerEintrag.Nebel" />
                                </div>
                                <div class="error-row mb-0">
                                    <span>Vertiefung</span>
                                    <input type="number" class="form-control text-center dark-input end-mini-input" @bind="NeuerEintrag.Vertiefung" />
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="error-box">
                                <h5>Interne Fehler</h5>
                                <div class="error-row">
                                    <span>&Ouml;lflecken</span>
                                    <input type="number" class="form-control text-center dark-input end-mini-input" @bind="NeuerEintrag.Oelflecken" />
                                </div>
                                <div class="error-row">
                                    <span>Tiefziehfehler / Blasen</span>
                                    <input type="number" class="form-control text-center dark-input end-mini-input" @bind="NeuerEintrag.Tiefziehfehler" />
                                </div>
                                <div class="error-row">
                                    <span>Fr&auml;s- / Stanzfehler</span>
                                    <input type="number" class="form-control text-center dark-input end-mini-input" @bind="NeuerEintrag.Fraesfehler" />
                                </div>
                                <div class="error-row">
                                    <span>Knicke / Wei&szlig;bruch</span>
                                    <input type="number" class="form-control text-center dark-input end-mini-input" @bind="NeuerEintrag.Knicke" />
                                </div>
                                <div class="error-row mb-0">
                                    <span>Kratzer</span>
                                    <input type="number" class="form-control text-center dark-input end-mini-input" @bind="NeuerEintrag.Kratzer" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-4 border-top border-secondary text-end d-flex flex-column flex-sm-row justify-content-end gap-2">
                        @if (IsEditMode)
                        {
                            <button class="btn btn-outline-light px-4 py-2 fw-bold" @onclick="ResetForm">Abbrechen</button>
                        }
                        <button class="btn end-save-btn px-5 py-2 fw-bold" @onclick="SaveEintrag">
                            <i class="fa-solid fa-save me-2"></i>@(IsEditMode ? "Aktualisieren" : "Speichern")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="content-card end-card mb-4">
        <div class="card-header-flex end-card-header flex-column flex-lg-row align-items-lg-center gap-2">
            <div>
                <h4 class="mb-1">Letzte Eintr&auml;ge</h4>
                <div class="text-secondary small">Zum Bearbeiten bitte auf den Button <strong>Bearbeiten</strong> klicken.</div>
            </div>
            <button class="btn btn-sm btn-outline-secondary" @onclick="LoadRecentEintraege"><i class="fa-solid fa-arrows-rotate me-1"></i>Neu laden</button>
        </div>

        <div id="endkontrolleScrollArea" class="table-responsive drag-scroll-area" style="max-height: 420px; overflow-y:auto;">
            <table class="table table-dark table-hover custom-table mb-0 end-table">
                <thead style="position: sticky; top:0; z-index: 1;">
                    <tr>
                        <th>ID</th>
                        <th>Aktion</th>
                        <th>L&ouml;schen</th>
                        <th style="min-width: 100px;">Charge</th>
                        <th style="min-width: 100px;">FA-Nr</th>
                        <th style="min-width: 120px;">Datum</th>
                        <th>Kunde</th>
                        <th>Projekt</th>
                        <th style="min-width: 200px;">Artikel</th>
                        <th>Dekor</th>
                        <th class="text-success">Gutteile</th>
                        <th>Fusseln</th>
                        <th>Nadelst.</th>
                        <th>Pickel</th>
                        <th>Dekorf.</th>
                        <th>Farbf.</th>
                        <th>Flecken</th>
                        <th>Nebel</th>
                        <th>Vertief.</th>
                        <th>&Ouml;lfleck.</th>
                        <th>Tiefzieh.</th>
                        <th>Fr&auml;s.</th>
                        <th>Knicke</th>
                        <th>Kratzer</th>
                        <th>Bemerkung</th>
                    </tr>
                </thead>
                <tbody>
                    @if (RecentEintraege.Count == 0)
                    {
                        <tr><td colspan="25" class="text-muted text-center py-3">Keine Datens&auml;tze vorhanden</td></tr>
                    }
                    @foreach (var e in RecentEintraege)
                    {
                        <tr class="@(SelectedEintragId == e.ID ? "end-row-selected" : "")">
                            <td class="fw-bold">#@e.ID</td>
                            <td>
                                <button class="btn btn-sm end-edit-btn" @onclick="() => EditEintrag(e)">Bearbeiten</button>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-link text-danger" @onclick="() => DeleteEintrag(e.ID)"><i class="fa-solid fa-trash"></i></button>
                            </td>
                            <td>@e.Charge</td>
                            <td>@e.FANr</td>
                            <td>@e.Datum.ToString("dd.MM.yyyy")</td>
                            <td>@e.Kunde</td>
                            <td>@e.Projekt</td>
                            <td>@e.Artikel</td>
                            <td>@e.Dekor</td>
                            <td class="text-success fw-bold">@e.Gutteile</td>
                            <td>@e.Fusseln</td>
                            <td>@e.Nadelstiche</td>
                            <td>@e.Pickel</td>
                            <td>@e.Dekorfehler</td>
                            <td>@e.Farbfehler</td>
                            <td>@e.Flecken</td>
                            <td>@e.Nebel</td>
                            <td>@e.Vertiefung</td>
                            <td>@e.Oelflecken</td>
                            <td>@e.Tiefziehfehler</td>
                            <td>@e.Fraesfehler</td>
                            <td>@e.Knicke</td>
                            <td>@e.Kratzer</td>
                            <td>@e.Bemerkung</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<CustomerData> Kunden = new();
    private List<string> Projekte = new();
    private List<string> ArtikelListe = new();
    private List<string> DekorListe = new();
    private List<EndkontrolleEintrag> RecentEintraege = new();
    private string UserPersonalnummer = "100";
    private string ActualUserName = "Unbekannt";
    private EndkontrolleEintrag NeuerEintrag = new();
    private bool IsEditMode;
    private int? SelectedEintragId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        ActualUserName = user?.Identity?.Name ?? "Unbekannt";
        UserPersonalnummer = user.Claims.FirstOrDefault(c => c.Type == "UserId")?.Value ?? UserService.Personalnummer;

        ResetForm();
        Kunden = await EndkontrolleService.GetCustomersAsync();
        await LoadRecentEintraege();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("eval", @"
                window.endkontrolleDragScroll = window.endkontrolleDragScroll || {
                    initPage: function (rootId) {
                        const root = document.getElementById(rootId);
                        if (!root || root.dataset.pageDragReady === '1') return;

                        root.dataset.pageDragReady = '1';

                        let isDown = false;
                        let startX = 0;
                        let startY = 0;
                        let scrollLeft = 0;
                        let scrollTop = 0;

                        const blockedSelector = 'button, input, select, textarea, a, label, option';
                        const scroller = root.closest('.content-scrollable') || document.scrollingElement || document.documentElement;

                        const stop = () => {
                            isDown = false;
                            root.classList.remove('page-dragging');
                            document.body.classList.remove('drag-scroll-lock');
                        };

                        const preventSelection = (e) => {
                            if (isDown) e.preventDefault();
                        };

                        const onMove = (e) => {
                            if (!isDown) return;
                            e.preventDefault();
                            scroller.scrollTop = scrollTop - (e.pageY - startY);
                        };

                        root.addEventListener('mousedown', (e) => {
                            if (e.button !== 0) return;
                            if (e.target.closest(blockedSelector)) return;
                            if (e.target.closest('.drag-scroll-area')) return;

                            isDown = true;
                            startX = e.pageX;
                            startY = e.pageY;
                            scrollLeft = scroller.scrollLeft;
                            scrollTop = scroller.scrollTop;
                            root.classList.add('page-dragging');
                            document.body.classList.add('drag-scroll-lock');
                            e.preventDefault();
                        });

                        document.addEventListener('mousemove', onMove);
                        document.addEventListener('mouseup', stop);
                        document.addEventListener('selectstart', preventSelection);
                    },

                    init: function (elementId) {
                        const el = document.getElementById(elementId);
                        if (!el || el.dataset.dragScrollReady === '1') return;

                        el.dataset.dragScrollReady = '1';

                        let isDown = false;
                        let startX = 0;
                        let startY = 0;
                        let scrollLeft = 0;
                        let scrollTop = 0;
                        let moved = false;

                        const blockedSelector = 'button, input, select, textarea, a, label';

                        const preventSelection = (e) => {
                            if (isDown) {
                                e.preventDefault();
                            }
                        };

                        const stop = () => {
                            isDown = false;
                            moved = false;
                            el.classList.remove('dragging');
                            document.body.classList.remove('drag-scroll-lock');
                        };

                        const onPointerMove = (e) => {
                            if (!isDown) return;
                            e.preventDefault();
                            moved = true;
                            const pageX = e.pageX ?? (e.touches && e.touches[0] ? e.touches[0].pageX : 0);
                            const pageY = e.pageY ?? (e.touches && e.touches[0] ? e.touches[0].pageY : 0);
                            el.scrollLeft = scrollLeft - (pageX - startX);
                            el.scrollTop = scrollTop - (pageY - startY);
                        };

                        const startDrag = (pageX, pageY, target) => {
                            if (target && target.closest && target.closest(blockedSelector)) return;
                            isDown = true;
                            moved = false;
                            startX = pageX;
                            startY = pageY;
                            scrollLeft = el.scrollLeft;
                            scrollTop = el.scrollTop;
                            el.classList.add('dragging');
                            document.body.classList.add('drag-scroll-lock');
                        };

                        el.addEventListener('mousedown', (e) => {
                            if (e.button !== 0) return;
                            startDrag(e.pageX, e.pageY, e.target);
                            if (isDown) {
                                e.preventDefault();
                            }
                        });

                        document.addEventListener('mousemove', onPointerMove);
                        document.addEventListener('mouseup', stop);
                        document.addEventListener('selectstart', preventSelection);
                        el.addEventListener('dragstart', preventSelection);

                        el.addEventListener('touchstart', (e) => {
                            const touch = e.touches && e.touches[0];
                            if (!touch) return;
                            startDrag(touch.pageX, touch.pageY, e.target);
                        }, { passive: true });

                        document.addEventListener('touchmove', onPointerMove, { passive: false });
                        document.addEventListener('touchend', stop, { passive: true });

                        el.addEventListener('click', (e) => {
                            if (moved) {
                                e.preventDefault();
                                e.stopPropagation();
                            }
                        }, true);
                    }
                };
                window.endkontrolleDragScroll.initPage('endkontrollePageDragSurface');
                window.endkontrolleDragScroll.init('endkontrolleScrollArea');
            ");
        }
    }

    private async Task OnKundeChanged(ChangeEventArgs e)
    {
        NeuerEintrag.Kunde = e.Value?.ToString() ?? "";
        NeuerEintrag.Projekt = "";
        NeuerEintrag.Artikel = "";
        NeuerEintrag.Dekor = "";
        Projekte.Clear();
        ArtikelListe.Clear();
        DekorListe.Clear();

        if (!string.IsNullOrEmpty(NeuerEintrag.Kunde))
        {
            Projekte = await EndkontrolleService.GetProjectsAsync(NeuerEintrag.Kunde);
            if (Projekte.Count == 1)
            {
                await OnProjektChanged(new ChangeEventArgs { Value = Projekte[0] });
            }
        }
    }

    private async Task OnProjektChanged(ChangeEventArgs e)
    {
        NeuerEintrag.Projekt = e.Value?.ToString() ?? "";
        NeuerEintrag.Artikel = "";
        NeuerEintrag.Dekor = "";
        ArtikelListe.Clear();
        DekorListe.Clear();

        if (!string.IsNullOrEmpty(NeuerEintrag.Projekt))
        {
            var res = await EndkontrolleService.GetArtikelsAndDekorsAsync(NeuerEintrag.Projekt);
            ArtikelListe = res.Artikels;
            DekorListe = res.Dekors;

            if (ArtikelListe.Count == 1) NeuerEintrag.Artikel = ArtikelListe[0];
            if (DekorListe.Count == 1) NeuerEintrag.Dekor = DekorListe[0];
        }
    }

    private async Task SaveEintrag()
    {
        if (string.IsNullOrWhiteSpace(NeuerEintrag.Charge) || string.IsNullOrWhiteSpace(NeuerEintrag.FANr) ||
            string.IsNullOrWhiteSpace(NeuerEintrag.Artikel) || string.IsNullOrWhiteSpace(NeuerEintrag.Dekor))
        {
            await JS.InvokeVoidAsync("alert", "Bitte f\u00fclle Charge, FA-Nr, Artikel und Dekor aus.");
            return;
        }

        NeuerEintrag.Personalnummer = UserPersonalnummer;

        var res = IsEditMode
            ? await EndkontrolleService.UpdateEintragAsync(NeuerEintrag, ActualUserName)
            : await EndkontrolleService.InsertEintragAsync(NeuerEintrag, ActualUserName);

        if (res.Success)
        {
            await JS.InvokeVoidAsync("alert", IsEditMode ? "Eintrag erfolgreich aktualisiert." : "Eintrag erfolgreich gespeichert.");

            if (IsEditMode)
            {
                ReplaceRecentEintrag(NeuerEintrag);
            }
            else
            {
                await LoadRecentEintraege();
            }

            ResetForm();
        }
        else
        {
            await JS.InvokeVoidAsync("alert", res.Message);
        }
    }

    private async Task LoadRecentEintraege()
    {
        RecentEintraege = await EndkontrolleService.GetRecentEintraegeAsync(UserPersonalnummer);
    }

    private async Task DeleteEintrag(int id)
    {
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Diesen Eintrag wirklich l\u00f6schen?");
        if (confirm)
        {
            await EndkontrolleService.DeleteEintragAsync(id, ActualUserName);
            await LoadRecentEintraege();
            if (SelectedEintragId == id)
            {
                ResetForm();
            }
        }
    }

    private async Task EditEintrag(EndkontrolleEintrag eintrag)
    {
        SelectedEintragId = eintrag.ID;
        IsEditMode = true;
        NeuerEintrag = CloneEintrag(eintrag);
        NeuerEintrag.Personalnummer = UserPersonalnummer;

        Projekte.Clear();
        ArtikelListe.Clear();
        DekorListe.Clear();

        if (!string.IsNullOrWhiteSpace(NeuerEintrag.Kunde))
        {
            Projekte = await EndkontrolleService.GetProjectsAsync(NeuerEintrag.Kunde);
        }

        if (!string.IsNullOrWhiteSpace(NeuerEintrag.Projekt))
        {
            var res = await EndkontrolleService.GetArtikelsAndDekorsAsync(NeuerEintrag.Projekt);
            ArtikelListe = res.Artikels;
            DekorListe = res.Dekors;
        }
    }

    private void ResetForm()
    {
        IsEditMode = false;
        SelectedEintragId = null;
        NeuerEintrag = new EndkontrolleEintrag
        {
            Datum = DateTime.Today,
            Personalnummer = UserPersonalnummer
        };
    }

    private void ReplaceRecentEintrag(EndkontrolleEintrag updated)
    {
        var index = RecentEintraege.FindIndex(x => x.ID == updated.ID);
        if (index >= 0)
        {
            RecentEintraege[index] = CloneEintrag(updated);
        }
    }

    private static EndkontrolleEintrag CloneEintrag(EndkontrolleEintrag source) => new()
    {
        ID = source.ID,
        Charge = source.Charge,
        FANr = source.FANr,
        Kunde = source.Kunde,
        Projekt = source.Projekt,
        Artikel = source.Artikel,
        Dekor = source.Dekor,
        Datum = source.Datum == default ? DateTime.Today : source.Datum,
        Gutteile = source.Gutteile,
        Fusseln = source.Fusseln,
        Nadelstiche = source.Nadelstiche,
        Pickel = source.Pickel,
