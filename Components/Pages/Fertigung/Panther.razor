@page "/fertigung/panther"
@using QIN_Production_Web.Data
@using Microsoft.AspNetCore.Components

<PageTitle>Panther - QR Generator & Kontrolle</PageTitle>

<div class="dashboard-header mb-4">
    <h2>Thermoformung Panther</h2>
    <p class="text-secondary">QR-Code Generator & Plattenkontrolle</p>
</div>

<!-- Tabs Instead of separate Window grids -->
<ul class="nav nav-tabs mb-4 custom-tabs">
    <li class="nav-item">
        <a class="nav-link @(ActiveTab == "control" ? "active" : "")" @onclick='() => ActiveTab = "control"' style="cursor:pointer;">Plattenkontrolle</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(ActiveTab == "qr" ? "active" : "")" @onclick='() => ActiveTab = "qr"' style="cursor:pointer;">QR-Code Generator</a>
    </li>
</ul>

@if(ActiveTab == "qr")
{
    <div class="row g-4 mb-4">
        <!-- Generator Card -->
        <div class="col-md-5">
            <div class="content-card h-100">
                <div class="card-header-flex">
                    <h4>QR Generator</h4>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <label class="form-label text-secondary">Ausgewählte FA-Nr</label>
                        <input type="text" class="form-control dark-input" readonly value="@SelectedAuftragFANR" />
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 p-3 border border-secondary rounded" style="background-color: var(--panel-color) !important;">
                        <span class="text-secondary">Generierter Code:</span>
                        <strong class="text-primary fs-5">@(string.IsNullOrEmpty(SelectedAuftragFANR) ? "Keine" : SelectedAuftragFANR)</strong>
                    </div>

                    <button class="btn btn-primary w-100 py-3" disabled="@(string.IsNullOrEmpty(SelectedAuftragFANR))">
                        <i class="fa-solid fa-print me-2"></i>QR-Code Drucken
                    </button>
                    <small class="text-muted mt-2 d-block text-center">(Druckfunktion ist derzeit nur im Desktop-Client verfügbar)</small>
                </div>
            </div>
        </div>

        <!-- Auftrags List -->
        <div class="col-md-7">
            <div class="content-card h-100">
                <div class="card-header-flex">
                 <h4>Auftragsliste wählen</h4>
                 <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAuftraege"><i class="fa-solid fa-arrows-rotate"></i></button>
                </div>
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-dark table-hover custom-table mb-0">
                        <thead style="position: sticky; top: 0; background-color: var(--panel-color); z-index: 1;">
                            <tr>
                                <th>FA Nr</th>
                                <th>Material</th>
                                <th>Menge</th>
                                <th>Maschine</th>
                                <th>Datum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if(Auftraege == null || !Auftraege.Any()) {
                                <tr><td colspan="5" class="text-center text-muted">Keine Aufträge gefunden. Lade...</td></tr>
                            } else {
                                foreach(var row in Auftraege)
                                {
                                    <tr @onclick="() => SelectAuftrag(row)" class="cursor-pointer @(SelectedAuftragFANR == row.FANR ? "table-active" : "")">
                                        <td>@row.FANR</td>
                                        <td>@row.Material</td>
                                        <td>@row.Liefermenge</td>
                                        <td>@row.MaschinenNr</td>
                                        <td>@(row.EintragsDate?.ToString("dd.MM.yyyy"))</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}
else if(ActiveTab == "control")
{
     <div class="row g-4 mb-4">
        <div class="col-md-5">
            <div class="content-card h-100">
                 <div class="card-header-flex">
                    <h4>Platten Scanner</h4>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <label class="form-label text-secondary">QR-Code scannen (Charge)</label>
                        <input type="text" class="form-control dark-input form-control-lg text-center fw-bold" @bind="ScanCode" @bind:event="oninput" placeholder="Warte auf Scan..." autofocus />
                    </div>

                    <p class="text-center text-secondary mb-3">Zustand der Platte auswählen</p>
                    
                    <div class="d-flex gap-3 justify-content-center">
                        <button class="btn btn-danger px-4 py-3" @onclick="() => ProcessScan(true)">Ausschuss</button>
                        <button class="btn btn-success px-4 py-3" @onclick="() => ProcessScan(false)">Sammelausschuss</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="content-card h-100">
                 <div class="card-header-flex">
                    <h4>Scan Protokoll</h4>
                    @if(Log.Any()) { <button class="btn btn-sm btn-outline-danger" @onclick="() => Log.Clear()"><i class="fa-solid fa-trash me-2"></i>Leeren</button> }
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush" style="max-height: 350px; overflow-y:auto; border-radius: 0 0 10px 10px; background-color: var(--panel-color);">
                        @foreach(var entry in Log)
                        {
                            <li class="list-group-item border-secondary px-4 py-3" style="background-color: transparent;">
                                <span class="d-block">@entry.Message</span>
                                <small class="text-muted">@entry.Time.ToString("HH:mm:ss")</small>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .custom-tabs {
        border-bottom: 2px solid var(--winBorderColor1);
    }
    .custom-tabs .nav-link {
        color: var(--plainTextColor1);
        border: none;
        padding: 12px 24px;
        font-weight: 500;
        background-color: transparent;
    }
    .custom-tabs .nav-link:hover {
        background-color: var(--panelColor2);
        color: white;
    }
    .custom-tabs .nav-link.active {
        background-color: transparent;
        color: var(--color11);
        border-bottom: 3px solid var(--color11);
    }
    .cursor-pointer { cursor: pointer; }
    
    /* Highlight the selected table active row specifically to overcome bootstrap overrides */
    .table-dark.table-hover tbody tr.table-active {
        background-color: rgba(255, 255, 255, 0.1) !important;
    }
</style>

@code {
    private string ActiveTab = "control"; // Defaulting to control as it's the main function
    private List<PantherAuftragsData> Auftraege = new();
    private string SelectedAuftragFANR = "";

    // Scanner state
    private string ScanCode = "";
    private List<LogEntry> Log = new();

    private class LogEntry {
        public MarkupString Message { get; set; }
        public DateTime Time { get; set; } = DateTime.Now;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAuftraege();
    }

    private async Task LoadAuftraege()
    {
        Auftraege = await PantherService.GetAuftraegeAsync();
    }

    private void SelectAuftrag(PantherAuftragsData row)
    {
        SelectedAuftragFANR = row.FANR ?? "";
    }

    private async Task ProcessScan(bool isAusschuss)
    {
        if (string.IsNullOrWhiteSpace(ScanCode)) return;

        var result = await PantherService.UpdateChargeZustandAsync(ScanCode, isAusschuss);
        
        string logMsg = result.Success 
            ? $"<span class='{(isAusschuss ? "text-danger" : "text-success")} fw-bold'><i class='fa-solid fa-check me-2'></i>{ScanCode} wurde als '{result.NewZustand}' markiert.</span>" 
            : $"<span class='text-warning fw-bold'><i class='fa-solid fa-xmark me-2'></i>{result.Message}</span>";

        Log.Insert(0, new LogEntry { Message = (MarkupString)logMsg }); 
        
        ScanCode = ""; // Clear for next scan
    }
}
