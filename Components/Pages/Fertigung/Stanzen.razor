@page "/fertigung/stanzen"
@using QIN_Production_Web.Data
@inject IJSRuntime JS

<PageTitle>Stanzen u. Fräsen</PageTitle>

<div class="dashboard-header mb-4">
    <h2>Stanzen u. Fräsen</h2>
    <p class="text-secondary">Produktionserfassung für Stanz- und Fräsanlagen</p>
</div>

<!-- Header / FA Selection -->
<div class="card bg-dark border-secondary mb-4 p-3 d-flex flex-row justify-content-between align-items-center" style="background-color: var(--panel-color) !important;">
    <div>
         <span class="text-muted me-3 fw-bold">FA-Nummer auswählen:</span>
         <select class="form-select d-inline-block w-auto dark-input" value="@SelectedFaNr" @onchange="OnFaNrChanged">
            <option value="">Bitte wählen...</option>
            @foreach(var fa in FaNrs) { <option value="@fa">@fa</option> }
        </select>
        
        <button class="btn btn-outline-info ms-2 btn-sm" @onclick="ToggleFaInfo">
            <i class="fa-solid fa-info-circle me-1"></i>FA-Info @(ShowFaInfo ? "verbergen" : "anzeigen")
        </button>
    </div>
    
    <div>
        <button class="btn btn-outline-secondary me-3 text-decoration-underline" style="border:none;">Freigabe Liste</button>
        <button class="btn @(IsFreigegeben ? "btn-success" : "btn-danger") fw-bold">Freigegeben: @(IsFreigegeben ? "Ja" : "Nein")</button>
    </div>
</div>

@if(ShowFaInfo && FaInfo != null)
{
    <div class="alert alert-dark border-info text-light mb-4 shadow-sm" style="background-color: var(--panel-color-2);">
        <h5 class="alert-heading text-info border-bottom border-secondary pb-2"><i class="fa-solid fa-circle-info me-2"></i>Auftragsinformationen</h5>
        <div class="row mt-3">
            <div class="col-md-3"><strong>Material-Nr:</strong><br/> @(string.IsNullOrEmpty(FaInfo.MaterialNr) ? "-" : FaInfo.MaterialNr)</div>
            <div class="col-md-3"><strong>Beschreibung:</strong><br/> @FaInfo.Beschreibung1 <br/> @FaInfo.Beschreibung2</div>
            <div class="col-md-2"><strong>Datum:</strong><br/> @(FaInfo.Auftragsdatum?.ToString("dd.MM.yyyy") ?? "-")</div>
            <div class="col-md-2"><strong>Auftragsmenge:</strong><br/> <span class="text-warning fw-bold fs-5">@FaInfo.Auftragsmenge</span></div>
            <div class="col-md-2"><strong>Chargenanzahl:</strong><br/> @FaInfo.Chargenanzahl</div>
        </div>
    </div>
}

<div class="row g-4 mb-4">
    <!-- Eingabe Panel -->
    <div class="col-md-5">
        <div class="content-card h-100">
             <div class="card-header-flex">
                <h4>Erfassung Produktion</h4>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label text-secondary">Maschinen-Nr.</label>
                    <input type="number" class="form-control dark-input" @bind="NeuerAuftrag.MaschinenNr" placeholder="Bsp: 101" />
                </div>
                
                 <div class="mb-3">
                    <label class="form-label text-secondary">Datum</label>
                    <input type="date" class="form-control dark-input" @bind="NeuerAuftrag.Datum" />
                </div>
                
                <div class="row g-3 mb-3">
                    <div class="col-6">
                         <label class="form-label text-secondary">Beginnzeit</label>
                         <input type="time" class="form-control dark-input" @bind="NeuerAuftrag.Begin" />
                    </div>
                     <div class="col-6">
                         <label class="form-label text-secondary">Endzeit</label>
                         <input type="time" class="form-control dark-input" @bind="NeuerAuftrag.Ende" />
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-6">
                         <label class="form-label text-secondary">Pausenzeit (Min.)</label>
                         <input type="number" class="form-control dark-input" @bind="NeuerAuftrag.Pausen" />
                    </div>
                     <div class="col-6">
                         <label class="form-label text-secondary">Ausfallzeit (Min.)</label>
                         <input type="number" class="form-control dark-input" @bind="NeuerAuftrag.Ausfall" />
                    </div>
                </div>
                
                <div class="mb-4">
                    <label class="form-label text-secondary">Bemerkung</label>
                    <input type="text" class="form-control dark-input" @bind="NeuerAuftrag.Bemerkung" />
                </div>
                
                <button class="btn btn-primary w-100 py-2" @onclick="AddAuftrag">
                    <i class="fa-solid fa-plus me-2"></i>Eintrag hinzufügen
                </button>
            </div>
        </div>
    </div>

    <!-- Chargen Panel -->
    <div class="col-md-7">
        <div class="content-card h-100 d-flex flex-column">
             <div class="card-header-flex">
                <h4>Chargen & Mengen</h4>
                @if(FaInfo != null) {
                    <span class="badge bg-secondary p-2">Summe erfasst: @(Chargen.Sum(x => x.Menge)) / @FaInfo.Auftragsmenge</span>
                }
            </div>
            
            <!-- Quick Charge Add if needed -->
            <div class="card-body border-bottom border-secondary mb-3 pb-4">
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label text-secondary small">Charge (Manuell füllen)</label>
                        <select class="form-select dark-input form-select-sm" @bind="SelectedChargeToAdd">
                            <option value="">Charge aus Liste wählen...</option>
                            @foreach(var c in Chargen.Where(x => x.Menge == 0)) {
                                <option value="@c.Charge">@c.Charge</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-secondary small">Menge</label>
                        <input type="number" class="form-control dark-input form-control-sm" @bind="NeueChargeMenge" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-secondary small">Ausschuss</label>
                        <input type="number" class="form-control dark-input form-control-sm text-danger" @bind="NeueChargeAusschuss" />
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-secondary btn-sm w-100" style="height: 31px;" @onclick="AddCharge">Add</button>
                    </div>
                </div>
            </div>

            <div class="table-responsive flex-grow-1" style="max-height: 320px; overflow-y:auto; padding: 0 16px;">
                <table class="table table-dark table-hover custom-table mb-0">
                    <thead style="position: sticky; top:0; background: var(--panel-color); z-index: 1;">
                        <tr>
                            <th>Charge</th>
                            <th>Menge</th>
                            <th>Ausschuss</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if(Chargen.Count == 0) {
                            <tr><td colspan="3" class="text-muted text-center py-3">Keine Chargen vorhanden</td></tr>
                        }
                        @foreach(var c in Chargen.Where(x => x.Menge > 0 || SelectedChargeToAdd == ""))
                        {
                            <tr>
                                <td class="align-middle fw-bold text-light">@c.Charge</td>
                                <td><input type="number" class="form-control form-control-sm dark-input text-warning fw-bold" @bind="c.Menge" /></td>
                                <td><input type="number" class="form-control form-control-sm dark-input text-danger fw-bold" @bind="c.Ausschuss" /></td>
                            </tr>
                        }
                    </tbody>
                </table>
                 <p class="text-muted small mt-2"><i class="fa-solid fa-circle-info me-1"></i>Sie können Chargen auch direkt in der Liste anpassen.</p>
            </div>
        </div>
    </div>
</div>

<div class="content-card mb-4">
    <div class="card-header-flex">
        <h4>Erfasste Auftragsliste (Zeiten)</h4>
    </div>
    <div class="table-responsive" style="max-height: 300px; overflow-y:auto;">
        <table class="table table-dark table-hover custom-table mb-0">
            <thead style="position: sticky; top:0; background: var(--panel-color); z-index: 1;">
                <tr>
                    <th>Maschine</th>
                    <th>Datum</th>
                    <th>Beginn</th>
                    <th>Ende</th>
                    <th>Pausen</th>
                    <th>Ausfall</th>
                    <th>Bemerkung</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if(Auftraege.Count == 0) {
                    <tr><td colspan="8" class="text-muted text-center py-3">Keine Datensätze vorhanden</td></tr>
                }
                @foreach(var a in Auftraege)
                {
                    <tr>
                        <td>@a.MaschinenNr</td>
                        <td>@a.Datum.ToString("dd.MM.yyyy")</td>
                        <td>@a.Begin.ToString(@"hh\:mm")</td>
                        <td>@a.Ende.ToString(@"hh\:mm")</td>
                        <td>@a.Pausen</td>
                        <td>@a.Ausfall</td>
                        <td>@a.Bemerkung</td>
                        <td>
                            @if(a.IsNewRowAuftrag) {
                                <button class="btn btn-sm btn-link text-danger" @onclick="() => Auftraege.Remove(a)"><i class="fa-solid fa-times"></i></button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card bg-dark border-secondary p-3 mt-4" style="background-color: var(--panel-color) !important;">
    <div class="d-flex justify-content-end align-items-center">
        <span class="text-secondary fw-bold me-3">Wenn der Auftrag komplett fertig ist absenden!</span>
        <div class="form-check form-switch me-4">
            <input class="form-check-input" type="checkbox" role="switch" id="absendenCheck" @bind="Abgesendet" style="transform: scale(1.3);">
            <label class="form-check-label text-warning fw-bold ms-2" for="absendenCheck" style="margin-top:2px;">Absenden</label>
        </div>
        <button class="btn btn-primary px-5 py-2 fw-bold" @onclick="SaveAll"><i class="fa-solid fa-save me-2"></i>Speichern</button>
    </div>
</div>

@code {
    private List<string> FaNrs = new();
    private string SelectedFaNr = "";
    private bool IsFreigegeben = false;
    
    private StanzenFaInfo? FaInfo = null;
    private bool ShowFaInfo = false;

    // Collections
    private List<StanzenCharge> Chargen = new();
    private List<StanzenEingabe> Auftraege = new();

    // New Auftrag Form
    private StanzenEingabe NeuerAuftrag = new StanzenEingabe { IsNewRowAuftrag = true };
    
    // Quick Add Charge
    private string SelectedChargeToAdd = "";
    private int NeueChargeMenge = 0;
    private int NeueChargeAusschuss = 0;

    // Save state
    private bool Abgesendet = false;

    protected override async Task OnInitializedAsync()
    {
        FaNrs = await StanzenService.GetOpenFANrsAsync();
    }

    private async Task OnFaNrChanged(ChangeEventArgs e)
    {
        SelectedFaNr = e.Value?.ToString() ?? "";
        FaInfo = null;
        ShowFaInfo = false;
        Chargen.Clear();
        Auftraege.Clear();
        
        if (string.IsNullOrEmpty(SelectedFaNr)) return;

        var data = await StanzenService.GetDataForFaAsync(SelectedFaNr);
        Chargen = data.Chargen;
        Auftraege = data.Auftraege;

        FaInfo = await StanzenService.GetFaInfoAsync(SelectedFaNr);
        IsFreigegeben = await StanzenService.CheckFreigabeAsync(SelectedFaNr);
    }
    
    private void ToggleFaInfo() => ShowFaInfo = !ShowFaInfo;

    private void AddAuftrag()
    {
        if (NeuerAuftrag.MaschinenNr <= 0) return;
        
        // Check exact duplicate locally
        bool exists = Auftraege.Any(a => 
            a.MaschinenNr == NeuerAuftrag.MaschinenNr && 
            a.Datum.Date == NeuerAuftrag.Datum.Date && 
            a.Begin == NeuerAuftrag.Begin && 
            a.Ende == NeuerAuftrag.Ende && 
            a.Pausen == NeuerAuftrag.Pausen && 
            a.Ausfall == NeuerAuftrag.Ausfall);
            
        if (exists)
        {
            JS.InvokeVoidAsync("alert", "Ein identischer Eintrag existiert bereits.");
            return;
        }

        Auftraege.Add(new StanzenEingabe {
            MaschinenNr = NeuerAuftrag.MaschinenNr,
            Datum = NeuerAuftrag.Datum,
            Begin = NeuerAuftrag.Begin,
            Ende = NeuerAuftrag.Ende,
            Pausen = NeuerAuftrag.Pausen,
            Ausfall = NeuerAuftrag.Ausfall,
            Bemerkung = NeuerAuftrag.Bemerkung,
            IsNewRowAuftrag = true
        });

        // Reset part of the form
        NeuerAuftrag.Bemerkung = "";
        NeuerAuftrag.Pausen = 0;
        NeuerAuftrag.Ausfall = 0;
    }
    
    private void AddCharge()
    {
        if(string.IsNullOrEmpty(SelectedChargeToAdd)) return;
        var existing = Chargen.FirstOrDefault(x => x.Charge == SelectedChargeToAdd);
        if(existing != null)
        {
            existing.Menge = NeueChargeMenge;
            existing.Ausschuss = NeueChargeAusschuss;
        }
        
        SelectedChargeToAdd = "";
        NeueChargeMenge = 0;
        NeueChargeAusschuss = 0;
    }

    private async Task SaveAll()
    {
        if(string.IsNullOrEmpty(SelectedFaNr)) return;

        int zielMenge = FaInfo?.Auftragsmenge ?? 0;
        var result = await StanzenService.SaveAuftraegeUndChargenAsync(SelectedFaNr, Abgesendet, Auftraege, Chargen, zielMenge);
        
        if (result.Success)
        {
            await JS.InvokeVoidAsync("alert", result.Message);
            
            if (Abgesendet)
            {
                FaNrs = await StanzenService.GetOpenFANrsAsync();
                SelectedFaNr = "";
                Auftraege.Clear();
                Chargen.Clear();
                FaInfo = null;
                ShowFaInfo = false;
            }
            else
            {
               await OnFaNrChanged(new ChangeEventArgs { Value = SelectedFaNr }); // Reload
               foreach(var a in Auftraege) a.IsNewRowAuftrag = false;
            }
        }
        else
        {
            await JS.InvokeVoidAsync("alert", result.Message);
        }
    }
}
