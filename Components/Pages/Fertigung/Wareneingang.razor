@page "/fertigung/wareneingang"
@rendermode InteractiveServer
@using QIN_Production_Web.Data
@using QIN_Production_Web.Helpers
@using Microsoft.AspNetCore.Components.Authorization
@using System.Globalization
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
<PageTitle>Wareneingang - Fertigung</PageTitle>

<div class="wareneingang-dashboard pb-5">

    <!-- HEADER & ACTION BAR -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h1 class="fw-bold mb-1 text-white" style="font-size: 2rem; letter-spacing: -0.02em;">Wareneingang</h1>
            <p class="text-secondary mb-0">Produktionsmaterial erfassen · Charger-Verwaltung · Etikettendruck</p>
        </div>
        
        <div class="d-flex align-items-center gap-3 glass-card py-2 px-4" style="height: auto;">
            <div class="me-3 border-end border-secondary pe-4">
                <span class="modern-label d-block mb-1 text-secondary">System Status</span>
                @if(IsEditMode)
                {
                    <span class="status-badge status-mittel"><i class="fa-solid fa-pen-to-square me-1"></i>Edit (ID: @SelectedEntry?.ID)</span>
                }
                else
                {
                    <span class="status-badge status-gut"><i class="fa-solid fa-plus-circle me-1"></i>Neuerfassung</span>
                }
            </div>
            <button class="btn btn-glass px-3 py-2 fw-bold text-white" @onclick="RefreshForm" title="Formular zurücksetzen">
                <i class="fa-solid fa-rotate-left"></i> Leeren
            </button>
            <button class="btn btn-gradient-success px-4 fw-bold text-white" @onclick="SaveEintrag">
                <i class="fa-solid fa-save me-2"></i> @(IsEditMode ? "Änderungen Speichern" : "Wareneingang Buchen")
            </button>
        </div>
    </div>

    <!-- MAIN 3-COLUMN LAYOUT -->
    <div class="row g-4 mb-4 align-items-stretch">
        
        <!-- LEFT: STAMMDATEN -->
        <div class="col-xl-6 col-lg-6">
            <div class="glass-card d-flex flex-column h-100">
                <div class="card-title-modern">
                    <i class="fa-solid fa-clipboard-list text-primary me-2"></i> Stammdaten
                </div>
                
                <div class="row g-3 mb-3">
                    <div class="col-12">
                        <label class="modern-label">Lieferant</label>
                        <select class="form-select modern-select fw-bold @LieferantFieldClass" value="@SelectedLieferant" @onchange="OnLieferantChanged">
                            <option value="">Bitte wählen...</option>
                            @foreach(var l in Lieferanten) { <option value="@l">@l</option> }
                        </select>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-4">
                        <label class="modern-label">Lieferschein</label>
                        <input type="text" class="form-control modern-input fw-bold text-white @LieferscheinFieldClass" @bind="Lieferschein" placeholder="LS-123" />
                    </div>
                    <div class="col-4">
                        <label class="modern-label">Position</label>
                        <input type="text" class="form-control modern-input fw-bold text-white" @bind="Pos" placeholder="z.B. 10" />
                    </div>
                    <div class="col-4">
                        <label class="modern-label">EBE-Nr.</label>
                        <input type="text" class="form-control modern-input fw-bold text-white" @bind="EBE" placeholder="EBE-99" />
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <label class="modern-label">Zustand der Ware</label>
                        <select class="form-select modern-select fw-bold @ZustandFieldClass" @bind="Zustand">
                            <option value="">Bitte wählen...</option>
                            <option value="Gut">Gut (Keine Mängel)</option>
                            <option value="Mittel">Mittel (Leichte Mängel)</option>
                            <option value="Schlecht">Schlecht (QS-Fall)</option>
                        </select>
                    </div>
                    <div class="col-6 d-flex flex-column pb-1">
                        <label class="modern-label mb-2">Palettentausch</label>
                        <div class="d-flex gap-4 align-items-center mb-2">
                            <div class="form-check">
                                <input class="form-check-input fw-bold" style="width: 1.2rem; height: 1.2rem;" type="radio" name="palSelect" id="palJa" checked="@(Palettentausch)" @onchange="@(e => Palettentausch = true)">
                                <label class="form-check-label text-white ms-1 fw-bold fs-6" style="cursor:pointer;" for="palJa">
                                    Ja
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input fw-bold" style="width: 1.2rem; height: 1.2rem;" type="radio" name="palSelect" id="palNein" checked="@(!Palettentausch)" @onchange="@(e => Palettentausch = false)">
                                <label class="form-check-label text-white ms-1 fw-bold fs-6" style="cursor:pointer;" for="palNein">
                                    Nein
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                @if (IsDickenmessungRelevant)
                {
                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <label class="modern-label">Dickenmessung</label>
                            <div class="input-group">
                                <input type="text" class="form-control modern-input fw-bold text-white @DickenmessungFieldClass"
                                       @bind="Dickenmessung"
                                       placeholder="z.B. 0,23"
                                       inputmode="decimal" />
                                <span class="input-group-text border-0 text-secondary fw-bold px-3" style="background: rgba(15, 23, 42, 0.8);">mm</span>
                            </div>
                            <small class="text-secondary">Pflichtfeld. Erlaubt sind nur Werte zwischen 0,23 und 1,2 mm.</small>
                        </div>
                    </div>
                }

                <div class="mt-auto">
                    <label class="modern-label">Zusätzliche Bemerkung</label>
                    <textarea class="form-control modern-input text-white custom-placeholder @BemerkungFieldClass" rows="4" @bind="Bemerkung" placeholder="Optionale Notizen... (Pflichtfeld bei Palettentausch oder Zustand 'Schlecht')"></textarea>
                </div>
            </div>
        </div>

        <!-- RIGHT: CHARGENERFASSUNG -->
        <div class="col-xl-6 col-lg-6">
            <div class="glass-card d-flex flex-column h-100" style="border-top: 4px solid #3b82f6;">
                <div class="card-title-modern d-flex justify-content-between align-items-center">
                    <div><i class="fa-solid fa-barcode text-primary me-2"></i> Chargen Erfassung</div>
                    <div class="badge bg-primary px-3 py-2 fs-6 rounded-pill">Gesamt: @GesamtLaufmeter LM/STK</div>
                </div>

                <!-- HUGE SCANNER INPUT -->
                <div class="mb-4">
                    <label class="modern-label text-center w-100 d-block mb-1">Barcode Scanner bereit</label>
                    <input id="chargeInput" type="text" class="form-control scanner-focus w-100 mx-auto" 
                           style="height: 80px;"
                           placeholder="Charge scannen..." 
                           @bind="NewCharge" @bind:event="oninput" @onkeyup="HandleKeyUp" autocomplete="off" />
                </div>

                <div class="row g-2 mb-4">
                    <div class="col-md-7">
                        <label class="modern-label">Menge (Laufmeter/Stück)</label>
                        <div class="input-group">
                            <input type="number" class="form-control modern-input text-warning fw-bold fs-5 text-end pe-3" placeholder="0" @bind="NewMenge" @onkeyup="HandleKeyUp" />
                            <span class="input-group-text border-0 text-secondary fw-bold px-3" style="background: rgba(15, 23, 42, 0.8);">LM/STK</span>
                        </div>
                    </div>
                    <div class="col-md-5 d-flex align-items-end">
                        <button class="btn btn-gradient-primary w-100 h-100 fs-5" @onclick="() => AddCharge(false)" style="min-height: 48px;">
                            <i class="fa-solid fa-plus me-1"></i> Hinzufügen
                        </button>
                    </div>
                </div>

                <div class="modern-table-container flex-grow-1 mb-4" style="min-height: 200px; max-height: 350px; overflow-y: auto;">
                    <table class="modern-table">
                        <thead style="position: sticky; top:0; z-index:1;">
                            <tr>
                                <th style="width: 40px; text-align: center;"><i class="fa-solid fa-bolt"></i></th>
                                <th>Charge</th>
                                <th class="text-end">Menge</th>
                                <th style="width: 50px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if(ChargenList.Count == 0) {
                                <tr><td colspan="4" class="text-center text-secondary py-5">Keine Chargen erfasst.<br><small>Scannen Sie den ersten Barcode.</small></td></tr>
                            }
                            @foreach(var c in ChargenList)
                            {
                                <tr class="@(SelectedCharge == c ? "table-active" : "")" @onclick="() => SelectedCharge = c" style="cursor: pointer;">
                                    <td class="text-center text-primary"><i class="fa-solid @(c.Scanner == 1 ? "fa-barcode" : "fa-keyboard")"></i></td>
                                    <td class="fw-bold fs-6 text-white pt-3 pb-3">@c.Charge</td>
                                    <td class="text-end pt-2 pb-2">
                                        <div class="input-group input-group-sm justify-content-end" style="width: 150px; float: right;">
                                            <input type="text" class="form-control text-warning fw-bold border-secondary bg-transparent text-end" @bind="c.Menge" @bind:after="UpdateGesamtLaufmeter" />
                                            <span class="input-group-text bg-transparent border-secondary text-secondary opacity-75 fw-bold" style="border-left:0;">LM/STK</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm text-danger border-0 bg-transparent p-1" @onclick:stopPropagation="true" @onclick="() => RemoveCharge(c)">
                                            <i class="fa-solid fa-xmark fs-5"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-auto border-top pt-3" style="border-color: var(--border-color) !important;">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <label class="modern-label text-warning mb-1"><i class="fa-solid fa-print me-1"></i> Chargen-Etikett</label>
                            <p class="text-secondary small mb-0">Oeffnet die Druckansicht im Browser und zeigt den normalen Druckdialog</p>
                        </div>
                        <button class="btn btn-glass px-4 py-2 fw-bold text-white border-primary" style="background: rgba(59, 130, 246, 0.1);" disabled="@(SelectedCharge == null)" @onclick="PrintSelectedCharge">
                            <i class="fa-solid fa-print text-warning me-2"></i> Auswahl Drucken
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- BOTTOM: LETZTE WARENEINGÄNGE -->
    <div class="glass-card p-0 overflow-hidden mt-2 mb-4">
        <div class="p-4 border-bottom d-flex justify-content-between align-items-center" style="border-color: var(--border-color) !important;">
            <div>
                <h4 class="text-white fw-bold mb-1"><i class="fa-solid fa-clock-rotate-left text-primary me-2"></i> Letzte Buchungen (Historie)</h4>
                <span class="text-secondary small">Klicken Sie auf eine Zeile, um den Eintrag in die Maske oben zu laden.</span>
            </div>
            <button class="btn btn-glass btn-sm px-3" @onclick="RefreshHistorie"><i class="fa-solid fa-rotate me-2"></i>Aktualisieren</button>
        </div>
        
        <div class="modern-table-container border-0 rounded-0" style="max-height: 400px; overflow-y: auto;">
            <table id="historieTable" class="modern-table">
                <thead style="position: sticky; top:0; z-index: 1;">
                    <tr>
                        <th style="padding-left: 1.5rem; cursor: pointer;" @onclick='() => SortTable("ID")'>ID @GetSortIcon("ID")</th>
                        <th style="cursor: pointer;" @onclick='() => SortTable("Lieferschein")'>Lieferschein @GetSortIcon("Lieferschein")</th>
                        <th style="cursor: pointer;" @onclick='() => SortTable("Pos")'>Pos @GetSortIcon("Pos")</th>
                        <th style="cursor: pointer;" @onclick='() => SortTable("EBE")'>EBE-Nr. @GetSortIcon("EBE")</th>
                        <th style="cursor: pointer;" @onclick='() => SortTable("Lieferant")'>Lieferant @GetSortIcon("Lieferant")</th>
                        <th style="cursor: pointer;" @onclick='() => SortTable("Material")'>Material / Artikel @GetSortIcon("Material")</th>
                        <th class="text-end" style="cursor: pointer;" @onclick='() => SortTable("Menge")'>Gebuchte LM/STK @GetSortIcon("Menge")</th>
                        <th class="text-center" style="padding-right: 1.5rem; cursor: pointer;" @onclick='() => SortTable("Chargen")'>Anzahl Chargen @GetSortIcon("Chargen")</th>
                    </tr>
                </thead>
                <tbody>
                    @if(WarenList.Count == 0) {
                        <tr><td colspan="6" class="text-secondary text-center py-5">Keine Historie verfügbar.</td></tr>
                    }
                    @foreach(var w in WarenList)
                    {
                        <tr class="@(SelectedEntry?.ID == w.ID ? "table-active" : "")" @onclick="() => EditSelected(w)" style="cursor: pointer;">
                            <td class="fw-bold text-secondary pt-3 pb-3" style="padding-left: 1.5rem;">#@w.ID</td>
                            <td class="fw-bold text-white py-3">@w.LS_Nr</td>
                            <td class="text-white py-3">@w.Pos</td>
                            <td class="text-info fw-bold py-3">@w.EBE_NR</td>
                            <td class="text-white py-3">@w.Lieferant</td>
                            <td class="text-secondary py-3" style="max-width: 250px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;" title="@w.Artikel">@w.Artikel</td>
                            <td class="text-warning fw-bold text-end py-3">@w.Menge LM/STK</td>
                            <td class="text-center py-3" style="padding-right: 1.5rem;">
                                <span class="badge bg-secondary px-3 py-2 fs-6 rounded-pill">@w.Chargen</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@if (ShowChargeConfirmation)
{
    <div class="modal fade show d-block charge-confirmation-backdrop" tabindex="-1" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content charge-confirmation-modal text-white border-0">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title fw-bold">
                        <i class="fa-solid fa-circle-question text-warning me-2"></i>Charge prüfen
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CancelChargeConfirmation" aria-label="Schließen"></button>
                </div>
                <div class="modal-body text-center py-4 px-4">
                    <p class="text-secondary text-uppercase fw-semibold small mb-2">Bitte vor dem Hinzufügen kontrollieren</p>
                    <div class="charge-confirmation-value mb-3">@PendingCharge</div>
                    <div class="charge-confirmation-menge mb-4">@PendingMengeDisplay</div>
                    <p class="fs-5 fw-semibold mb-0">Ist diese Charge korrekt erfasst und die Menge geprüft?</p>
                </div>
                <div class="modal-footer border-secondary justify-content-center gap-2">
                    <button type="button" class="btn btn-glass px-4 py-2 fw-bold" @onclick="CancelChargeConfirmation">
                        <i class="fa-solid fa-pen me-2"></i>Nein, korrigieren
                    </button>
                    <button type="button" class="btn btn-gradient-success px-4 py-2 fw-bold" @onclick="ConfirmChargeAddition">
                        <i class="fa-solid fa-check me-2"></i>Ja, hinzufügen
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // Form
    private string Lieferschein = "";
    private string Pos = "";
    private string EBE = "";
    private string SelectedLieferant = "";
    private string Zustand = "Gut";
    private string Material = "";
    private string Dickenmessung = "";
    private string Bemerkung = "";
    private bool Palettentausch = false;
    
    private string NewCharge = "";
    private string NewMenge = "";
    private int GesamtLaufmeter = 0;
    
    private bool IsEditMode = false;
    private bool ShowChargeConfirmation = false;
    private bool IsSelectedLieferantAutomotiv = true;
    
    private List<string> Lieferanten = new();
    private List<string> Materialien = new();
    private List<ChargenEntry> ChargenList = new();
    private List<WareneingangEntry> WarenList = new();
    private WareneingangEntry? SelectedEntry;
    private ChargenEntry? SelectedCharge;
    private string PendingCharge = "";
    private string PendingMenge = "";
    
    private string SortColumn = "ID";
    private bool IsSortedAscending = false;
    private string PendingMengeDisplay => $"{(string.IsNullOrWhiteSpace(PendingMenge) ? "0" : PendingMenge)} LM/STK";
    private string LieferantFieldClass => GetRequiredFieldClass(IsLieferantMissing());
    private string LieferscheinFieldClass => GetRequiredFieldClass(IsLieferscheinMissing());
    private string ZustandFieldClass => GetRequiredFieldClass(IsZustandMissing());
    private string DickenmessungFieldClass => GetRequiredFieldClass(IsDickenmessungMissing());
    private string BemerkungFieldClass => GetRequiredFieldClass(IsBemerkungRequiredAndMissing());
    private bool IsDickenmessungRelevant => string.IsNullOrWhiteSpace(SelectedLieferant) || IsSelectedLieferantAutomotiv;
    private string GetRequiredFieldClass(bool isMissing) => IsEditMode && isMissing ? "required-outline" : string.Empty;

    protected override async Task OnInitializedAsync()
    {
        Lieferanten = await WareneingangService.GetLieferantenAsync();
        WarenList = await WareneingangService.LoadWareneingangAsync();
        SortWarenList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("makeTableResizable", "historieTable");
        }
    }

    private async Task OnLieferantChanged(ChangeEventArgs e)
    {
        SelectedLieferant = e.Value?.ToString() ?? "";
        await UpdateLieferantAutomotivStatusAsync(clearDickenmessungWhenNotRelevant: true);
        Materialien = await WareneingangService.FindAllMaterialsAsync(SelectedLieferant);
        WarenList = await WareneingangService.LoadWareneingangAsync(string.IsNullOrEmpty(SelectedLieferant) ? null : SelectedLieferant);
        SortWarenList();
    }

    private async Task UpdateLieferantAutomotivStatusAsync(bool clearDickenmessungWhenNotRelevant = false)
    {
        IsSelectedLieferantAutomotiv = await WareneingangService.IsLieferantAutomotivAsync(SelectedLieferant);
        if (clearDickenmessungWhenNotRelevant && !IsDickenmessungRelevant)
        {
            Dickenmessung = string.Empty;
        }
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddCharge(true);
        }
    }

    private async Task AddCharge(bool isEnterKey)
    {
        if (string.IsNullOrWhiteSpace(NewCharge)) return;

        if (isEnterKey)
        {
            await AddChargeToList(NewCharge.Trim(), NewMenge.Trim(), true);
            return;
        }

        PendingCharge = NewCharge.Trim();
        PendingMenge = string.IsNullOrWhiteSpace(NewMenge) ? "0" : NewMenge.Trim();
        ShowChargeConfirmation = true;
    }

    private async Task ConfirmChargeAddition()
    {
        await AddChargeToList(PendingCharge, PendingMenge, false);
        ResetPendingChargeConfirmation();
    }

    private async Task CancelChargeConfirmation()
    {
        ResetPendingChargeConfirmation();
        await FocusChargeInputAsync();
    }

    private async Task AddChargeToList(string charge, string menge, bool isScanner)
    {
        if (string.IsNullOrWhiteSpace(charge)) return;

        ChargenList.Add(new ChargenEntry
        {
            Charge = charge,
            Menge = string.IsNullOrWhiteSpace(menge) ? "0" : menge.Trim(),
            Scanner = isScanner ? 1 : 0,
            IsNew01 = 1
        });

        UpdateGesamtLaufmeter();

        NewCharge = "";
        NewMenge = "";
        await FocusChargeInputAsync();
    }

    private void ResetPendingChargeConfirmation()
    {
        ShowChargeConfirmation = false;
        PendingCharge = "";
        PendingMenge = "";
    }

    private async Task FocusChargeInputAsync()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('chargeInput').focus()");
    }

    private bool IsLieferantMissing() => string.IsNullOrWhiteSpace(SelectedLieferant);

    private bool IsLieferscheinMissing() => string.IsNullOrWhiteSpace(Lieferschein);

    private bool IsZustandMissing() => string.IsNullOrWhiteSpace(Zustand);

    private bool IsDickenmessungMissing() => IsDickenmessungRelevant && !TryNormalizeDickenmessung(Dickenmessung, out _);

    private bool IsBemerkungRequiredAndMissing()
    {
        return (Palettentausch || Zustand.Equals("Schlecht", StringComparison.OrdinalIgnoreCase))
            && string.IsNullOrWhiteSpace(Bemerkung);
    }

    private List<string> GetValidationErrors()
    {
        var errors = new List<string>();

        if (IsLieferscheinMissing())
        {
            errors.Add("Lieferschein eingeben.");
        }

        if (IsLieferantMissing())
        {
            errors.Add("Lieferant auswählen.");
        }

        if (IsZustandMissing())
        {
            errors.Add("Zustand der Ware auswählen.");
        }

        if (IsDickenmessungMissing())
        {
            errors.Add("Dickenmessung als Wert zwischen 0,23 mm und 1,2 mm eingeben.");
        }

        if (IsBemerkungRequiredAndMissing())
        {
            errors.Add("Zusätzliche Bemerkung eintragen, wenn Palettentausch aktiv ist oder der Zustand auf 'Schlecht' steht.");
        }

        return errors;
    }
    
    private void RemoveCharge(ChargenEntry entry)
    {
        ChargenList.Remove(entry);
        UpdateGesamtLaufmeter();
        if (SelectedCharge == entry) SelectedCharge = null;
    }
    
    private void UpdateGesamtLaufmeter()
    {
        GesamtLaufmeter = ChargenList.Sum(c => int.TryParse(c.Menge, out int m) ? m : 0);
    }

    private async Task SaveEintrag()
    {

        var validationErrors = GetValidationErrors();
        if (validationErrors.Count > 0)
        {
            var message = "Bitte folgende Pflichtfelder prüfen bzw. ausfüllen:\n\n- "
                + string.Join("\n- ", validationErrors);

            await JS.InvokeVoidAsync("alert", message);
            return;
        }

        string? normalizedDickenmessung = null;
        if (IsDickenmessungRelevant)
        {
            TryNormalizeDickenmessung(Dickenmessung, out var normalizedValue);
            normalizedDickenmessung = normalizedValue;
            Dickenmessung = normalizedValue;
        }
        else if (!string.IsNullOrWhiteSpace(Dickenmessung))
        {
            normalizedDickenmessung = Dickenmessung;
        }

        if (false && (Palettentausch || Zustand.Equals("Schlecht", StringComparison.OrdinalIgnoreCase)) && string.IsNullOrWhiteSpace(Bemerkung))
        {
            await JS.InvokeVoidAsync("alert", "Bitte geben Sie eine zusätzliche Bemerkung an (zwingend erforderlich bei Palettentausch oder mangelhaftem Zustand).");
            return;
        }

        if (false && !TryNormalizeDickenmessung(Dickenmessung, out _))
        {
            await JS.InvokeVoidAsync("alert", "Bitte eine gÃ¼ltige Dickenmessung zwischen 0,23 mm und 1,2 mm eingeben.");
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        string actualUserName = user.Identity?.Name ?? "Unbekannt";
        string pNummer = user.Claims.FirstOrDefault(c => c.Type == "UserId")?.Value ?? "100";
        var userSession = new UserSession { Name = actualUserName, Personalnummer = pNummer };

        bool ok = await WareneingangService.InsertWareneingangAsync(
            SelectedEntry?.ID.ToString(), SelectedLieferant, Lieferschein, Pos, ChargenList, 
            Zustand, GesamtLaufmeter.ToString(), Palettentausch, Bemerkung, userSession, IsEditMode, EBE, Material, normalizedDickenmessung);
            
        if (ok)
        {
            await JS.InvokeVoidAsync("alert", "Erfolgreich gespeichert!");

            // Send Email for every Wareneingang (Temporarily including Edits for debugging)
            // Capture data to avoid disposal issues
            string savedLieferschein = Lieferschein;
            string savedEBE = EBE;
            string savedLieferant = SelectedLieferant;
            string savedMaterial = Material ?? "N/A";
            string savedBemerkung = Bemerkung;
            string savedZustand = Zustand;

            _ = Task.Run(async () => {
                try {
                    string empfaenger = "qsintern@qin-form.de";
                    await EmailHelper.SendQSEmailAsync(savedLieferschein, savedEBE, savedLieferant, savedMaterial, savedBemerkung, actualUserName, empfaenger, savedZustand);
                } 
                catch (Exception ex) {
                    Console.WriteLine($"Fire-and-forget Email failed: {ex.Message}");
                }
            });

            WarenList = await WareneingangService.LoadWareneingangAsync(string.IsNullOrEmpty(SelectedLieferant) ? null : SelectedLieferant);
            RefreshForm();
        }
    }

    private async Task PrintSelectedCharge()
    {
        if (SelectedCharge == null || string.IsNullOrWhiteSpace(SelectedLieferant))
        {
            await JS.InvokeVoidAsync("alert", "Bitte eine Charge und Lieferant auswählen!");
            return;
        }
        
        try
        {
            string eingangsDatum = await WareneingangService.GetEingangsDatumForChargeAsync(SelectedCharge.Charge);
            string printHtml = WareneingangPrintHelper.BuildSingleChargePrintDocument(SelectedCharge.Charge, SelectedCharge.Menge, Material, eingangsDatum);
            await JS.InvokeVoidAsync("printHtmlDocument", printHtml);
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Druckansicht konnte nicht geöffnet werden: " + ex.Message);
        }
    }



    private async Task EditSelected(WareneingangEntry w)
    {
        if (w == null) return;
        SelectedEntry = w;

        IsEditMode = true;
        Lieferschein = SelectedEntry.LS_Nr ?? "";
        Pos = SelectedEntry.Pos ?? "";
        EBE = SelectedEntry.EBE_NR ?? "";
        SelectedLieferant = SelectedEntry.Lieferant ?? "";
        Zustand = SelectedEntry.Zustand ?? "";
        Dickenmessung = SelectedEntry.Dickenmessung ?? "";
        await UpdateLieferantAutomotivStatusAsync();
        
        Materialien = await WareneingangService.FindAllMaterialsAsync(SelectedLieferant);
        Material = SelectedEntry.Artikel ?? "";
        
        ChargenList = await WareneingangService.FindChargenAsync(SelectedEntry.ID);
        UpdateGesamtLaufmeter();
    }

    private void RefreshForm()
    {
        IsEditMode = false;
        SelectedEntry = null;
        SelectedCharge = null;
        Lieferschein = ""; Pos = ""; EBE = ""; SelectedLieferant = ""; Zustand = "Gut"; Material = ""; Dickenmessung = ""; Bemerkung = "";
        Palettentausch = false; ChargenList.Clear(); GesamtLaufmeter = 0;
        IsSelectedLieferantAutomotiv = true;
    }

    private static bool TryNormalizeDickenmessung(string? input, out string normalized)
    {
        normalized = string.Empty;

        if (string.IsNullOrWhiteSpace(input))
        {
            return false;
        }

        var cleaned = input.Trim()
            .Replace("mm", "", StringComparison.OrdinalIgnoreCase)
            .Replace(" ", "")
            .Replace(',', '.');

        if (!decimal.TryParse(cleaned, NumberStyles.AllowDecimalPoint, CultureInfo.InvariantCulture, out var value))
        {
            return false;
        }

        if (value < 0.23m || value > 1.2m)
        {
            return false;
        }

        normalized = value.ToString("0.##", new CultureInfo("de-DE"));
        return true;
    }

    private async Task RefreshHistorie()
    {
        WarenList = await WareneingangService.LoadWareneingangAsync();
        SortWarenList();
    }

    private void SortTable(string columnName)
    {
        if (SortColumn == columnName)
        {
            IsSortedAscending = !IsSortedAscending;
        }
        else
        {
            SortColumn = columnName;
            IsSortedAscending = true;
        }
        SortWarenList();
    }

    private void SortWarenList()
    {
        if (WarenList == null) return;
        switch (SortColumn)
        {
            case "Lieferschein": WarenList = IsSortedAscending ? WarenList.OrderBy(x => x.LS_Nr).ToList() : WarenList.OrderByDescending(x => x.LS_Nr).ToList(); break;
            case "Pos": WarenList = IsSortedAscending ? WarenList.OrderBy(x => x.Pos).ToList() : WarenList.OrderByDescending(x => x.Pos).ToList(); break;
            case "EBE": WarenList = IsSortedAscending ? WarenList.OrderBy(x => x.EBE_NR).ToList() : WarenList.OrderByDescending(x => x.EBE_NR).ToList(); break;
            case "Lieferant": WarenList = IsSortedAscending ? WarenList.OrderBy(x => x.Lieferant).ToList() : WarenList.OrderByDescending(x => x.Lieferant).ToList(); break;
            case "Material": WarenList = IsSortedAscending ? WarenList.OrderBy(x => x.Artikel).ToList() : WarenList.OrderByDescending(x => x.Artikel).ToList(); break;
            case "Menge": WarenList = IsSortedAscending ? WarenList.OrderBy(x => int.TryParse(x.Menge, out int m) ? m : 0).ToList() : WarenList.OrderByDescending(x => int.TryParse(x.Menge, out int m) ? m : 0).ToList(); break;
            case "Chargen": WarenList = IsSortedAscending ? WarenList.OrderBy(x => x.Chargen).ToList() : WarenList.OrderByDescending(x => x.Chargen).ToList(); break;
            default: WarenList = IsSortedAscending ? WarenList.OrderBy(x => x.ID).ToList() : WarenList.OrderByDescending(x => x.ID).ToList(); break;
        }
    }

    private RenderFragment GetSortIcon(string column)
    {
        if (SortColumn != column) return @<span></span>;
        if (IsSortedAscending) return @<i class="fa-solid fa-sort-up ms-1 text-primary"></i>;
        return @<i class="fa-solid fa-sort-down ms-1 text-primary"></i>;
    }
}

