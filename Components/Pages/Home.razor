@page "/"
@using QIN_Production_Web.Data
@using Microsoft.AspNetCore.Components.Authorization
@inject LoginService LoginService
@inject AlertService AlertService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Dashboard - QIN Production Web</PageTitle>

<div class="dashboard-header mb-5">
    <h2>Willkommen zurück, <strong>@UserName</strong>!</h2>
    <p class="text-secondary">Hier ist die Live-Übersicht deiner heutigen Produktion.</p>
</div>

<div class="row g-4 mb-4 align-items-stretch">
    <!-- Main Content Area -->
    <div class="col-xl-6 col-lg-12">
        <div class="content-card h-100">
            <div class="card-header-flex">
                <h4>Aktuelle Produktion</h4>
            </div>
            <div class="card-body">
                <div class="empty-state h-100 min-vh-25">
                    <i class="fa-solid fa-industry mb-3"></i>
                    <p>Produktionsdaten werden geladen...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Ankündigungen Sidebar -->
    <div class="col-xl-3 col-lg-6">
        <div class="content-card h-100">
            <div class="card-header-flex">
                <h4><i class="fa-solid fa-bullhorn text-primary me-2"></i> Ankündigungen</h4>
            </div>
            <div class="card-body p-0 overflow-auto custom-scrollbar" style="max-height: 500px;">
                @if (alerts.Count == 0)
                {
                    <div class="p-4 text-center text-secondary">
                        <small>Keine aktuellen Ankündigungen.</small>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush border-0">
                        @foreach (var alert in alerts)
                        {
                            <div class="list-group-item notification-item border-bottom border-dark m-0 rounded-0" @onclick="() => ReadAlert(alert)">
                                <div class="notif-dot @(!alert.IsRead ? "bg-blue shadow-sm" : "bg-secondary opacity-50") mt-1"></div>
                                <div class="notif-content w-100">
                                    <strong class="text-truncate d-block @(!alert.IsRead ? "text-white" : "text-secondary")">@alert.Title</strong>
                                    <span class="d-block text-truncate text-secondary" style="max-width: 90%;">
                                        @alert.Message
                                    </span>
                                    <div class="text-secondary mt-1" style="font-size: 0.75rem;">
                                        @alert.CreatedAt.ToShortDateString() • von @alert.CreatedBy
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Right Sidebar Area -->
    <div class="col-xl-3 col-lg-6">
        <div class="content-card h-100">
            <div class="card-header-flex">
                <h4><i class="fa-solid fa-users text-success me-2"></i> Wer ist online?</h4>
                <span class="badge bg-success rounded-pill">@onlineUsers.Count</span>
            </div>
            <div class="card-body p-0">
                @if (onlineUsers.Count == 0)
                {
                    <div class="p-4 text-center text-secondary">
                        <small>Keine anderen Benutzer aktiv.</small>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush border-0">
                        @foreach (var user in onlineUsers)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center border-bottom border-dark" style="background: transparent;">
                                <div class="d-flex align-items-center gap-3 py-2">
                                    <div class="position-relative">
                                        <i class="fa-solid fa-circle-user fs-2 text-info"></i>
                                        <span class="position-absolute bottom-0 end-0 p-1 bg-success border border-dark rounded-circle" style="width: 12px; height: 12px;"></span>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-white">@user.Name</div>
                                        <div class="text-secondary small">@user.Rechte</div>
                                    </div>
                                </div>
                                @if (user.Name != UserName)
                                {
                                    <button class="btn btn-sm btn-outline-primary rounded-pill px-3" @onclick="() => SendMessageTo(user)">
                                        <i class="fa-regular fa-comment-dots"></i> Nachricht
                                    </button>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Alert Modal -->
@if (selectedAlert != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6); backdrop-filter: blur(4px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white border-secondary shadow-lg">
                <div class="modal-header border-bottom border-secondary">
                    <h5 class="modal-title text-primary fw-bold">
                        <i class="fa-solid fa-bullhorn me-2"></i> @selectedAlert.Title
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseAlert"></button>
                </div>
                <div class="modal-body p-4">
                    <p style="white-space: pre-wrap; font-size: 1.1rem; line-height: 1.6;">@selectedAlert.Message</p>
                    
                    <div class="mt-4 pt-3 border-top border-secondary d-flex justify-content-between align-items-center text-secondary small">
                        <span><i class="fa-solid fa-user-pen me-2"></i>Erstellt von <strong>@selectedAlert.CreatedBy</strong></span>
                        <span><i class="fa-regular fa-calendar me-2"></i>@selectedAlert.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-secondary w-100 fw-bold" @onclick="CloseAlert">Schließen</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .dashboard-header h2 {
        font-size: 2.2rem;
        margin-bottom: 8px;
    }
    .dashboard-header p {
        font-size: 1.1rem;
        color: var(--text-secondary);
    }
    
    .content-card {
        background: var(--bg-card);
        border: var(--glass-border);
        border-radius: 16px;
        height: 100%;
        display: flex;
        flex-direction: column;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        overflow: hidden;
    }
    .card-header-flex {
        padding: 24px;
        border-bottom: var(--glass-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(30, 41, 59, 0.5);
    }
    .card-header-flex h4 { 
        margin: 0; 
        font-size: 1.25rem; 
        font-weight: 700;
        color: var(--text-primary);
    }
    
    .empty-state {
        min-height: 250px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--text-secondary);
        opacity: 0.5;
    }
    .empty-state i { font-size: 4rem; color: var(--text-secondary); }
    
    .notification-item {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        padding: 16px;
        border-radius: 12px;
        background: var(--bg-hover);
        transition: background 0.2s;
        cursor: pointer;
    }
    .notification-item:hover {
        background: var(--border-color);
    }
    .notif-dot { width: 12px; height: 12px; border-radius: 50%; margin-top: 5px; box-shadow: 0 0 10px #60a5fa;}
    .notif-content strong { display: block; color: var(--text-primary); font-size: 1rem; margin-bottom: 2px;}
    .notif-content span { color: var(--text-secondary); font-size: 0.85rem; }

    .btn-outline-primary {
        color: var(--accent-hover);
        border-color: var(--accent-hover);
    }
    .btn-outline-primary:hover {
        background-color: var(--accent-hover);
        color: #fff;
    }
    
    .border-dark {
        border-color: var(--border-color) !important;
    }

    /* Custom stealthy scrollbar for the widgets */
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: rgba(0,0,0,0.1); 
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: var(--border-color); 
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: var(--border-color); 
    }
</style>

@code {
    private List<UserSession> onlineUsers = new();
    private List<SystemAlert> alerts = new();
    private string UserName = "Benutzer";
    private string UserId = string.Empty;
    
    private SystemAlert? selectedAlert = null;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        UserName = authState.User?.Identity?.Name ?? "Benutzer";
        UserId = authState.User?.Claims.FirstOrDefault(c => c.Type == "UserId")?.Value ?? string.Empty;
        
        onlineUsers = await LoginService.GetOnlineUsersAsync();
        if (!string.IsNullOrEmpty(UserId))
        {
            alerts = await AlertService.GetRecentAlertsAsync(UserId);
        }
    }
    
    private void SendMessageTo(UserSession user)
    {
        NavigationManager.NavigateTo($"/nachrichten");
    }

    private async Task ReadAlert(SystemAlert alert)
    {
        selectedAlert = alert;
        if (!alert.IsRead && !string.IsNullOrEmpty(UserId))
        {
            alert.IsRead = true;
            await AlertService.MarkAlertAsReadAsync(alert.AlertID, UserId);
        }
    }

    private void CloseAlert()
    {
        selectedAlert = null;
    }
}

