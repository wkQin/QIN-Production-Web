@page "/login"
@using QIN_Production_Web.Data
@using Microsoft.AspNetCore.Components.Authorization
@inject LoginService LoginService
@inject LoginTokenCache TokenCache
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment Env
@rendermode InteractiveServer
@attribute [AllowAnonymous]
@layout EmptyLayout

<div class="login-wrapper container-fluid d-flex align-items-center justify-content-center vh-100">
    <div class="login-card glass-card p-5 text-center shadow-lg">
        <div class="mb-4">
            <i class="fa-solid fa-industry" style="font-size: 3rem; color: #3b82f6;"></i>
            <h2 class="mt-3 fw-bold text-white" style="letter-spacing: 1px;">QIN<span style="color: #3b82f6;">-FORM</span></h2>
            <p class="text-secondary mb-0">Production Web Access</p>
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger py-2 mb-4" role="alert">
                <i class="fa-solid fa-triangle-exclamation me-2"></i> @ErrorMessage
            </div>
        }

        <div class="mb-4 text-start">
            <label class="modern-label text-secondary mb-2">Benutzername oder Personalnummer</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-primary"><i class="fa-solid fa-user"></i></span>
                <input type="text" class="form-control modern-input text-white fw-bold" @bind="Username" @onkeyup="HandleKeyUp" placeholder="Username" autocomplete="username" />
            </div>
        </div>

        <div class="mb-5 text-start">
            <label class="modern-label text-secondary mb-2">Passwort</label>
            <div class="input-group">
                <span class="input-group-text bg-dark border-secondary text-primary"><i class="fa-solid fa-lock"></i></span>
                <input type="password" class="form-control modern-input text-white fw-bold" @bind="Password" @onkeyup="HandleKeyUp" placeholder="Passwort" autocomplete="current-password" />
            </div>
        </div>

        <div class="mb-4 text-start d-flex align-items-center">
            <div class="form-check form-switch custom-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="rememberMeSwitch" @bind="RememberMe">
                <label class="form-check-label text-secondary ms-2" for="rememberMeSwitch" style="cursor: pointer;">
                    Angemeldet bleiben
                </label>
            </div>
        </div>

        <button class="btn btn-gradient-primary w-100 py-3 fw-bold fs-5 text-white" @onclick="AuthenticateUser" tabindex="0" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                <span>Bitte warten...</span>
            }
            else
            {
                <i class="fa-solid fa-right-to-bracket me-2"></i> <span>Anmelden</span>
            }
        </button>



        <div class="mt-4 text-secondary small">
            &copy; @DateTime.Now.Year QIN Form GmbH & Co. KG
        </div>
    </div>
</div>

<style>
    .login-wrapper {
        background: linear-gradient(135deg, var(--bg-main) 0%, var(--bg-card) 100%);
        font-family: 'Inter', sans-serif;
    }

    .glass-card {
        background: rgba(30, 41, 59, 0.6);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        width: 100%;
        max-width: 450px;
    }

    .modern-input {
        background: rgba(15, 23, 42, 0.7);
        border: 1px solid var(--border-color);
        border-left: none;
        padding: 0.8rem 1rem;
        transition: all 0.3s ease;
    }

    .modern-input:focus {
        background: rgba(15, 23, 42, 0.9);
        border-color: #3b82f6;
        box-shadow: none;
        outline: none;
    }

    .input-group-text {
        background: rgba(15, 23, 42, 0.7) !important;
        border-right: none;
    }

    .input-group:focus-within .input-group-text {
        border-color: #3b82f6 !important;
    }
    
    .input-group:focus-within .modern-input {
        border-color: #3b82f6 !important;
    }

    .btn-gradient-primary {
        background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
        border: none;
        border-radius: 12px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
    }

    .btn-gradient-primary:hover {
        background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(37, 99, 235, 0.5);
    }
    .custom-switch .form-check-input:checked {
        background-color: #3b82f6;
        border-color: #3b82f6;
    }
</style>

@code {
    private string Username { get; set; } = string.Empty;
    private string Password { get; set; } = string.Empty;
    private bool RememberMe { get; set; } = true;
    private string ErrorMessage { get; set; } = string.Empty;

    private bool isLoading = false;

    [SupplyParameterFromQuery]
    private string? m { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(m))
        {
            // Pre-fill the username box from the Magic Link
            Username = m;
        }
    }

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !isLoading)
        {
            _ = AuthenticateUser();
        }
    }

    private async Task AuthenticateUser()
    {
        ErrorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(Username))
        {
            ErrorMessage = "Bitte Benutzername / Personalnummer eingeben.";
            return;
        }

        isLoading = true;
        StateHasChanged();

        UserSession? userSession = null;

        // Wenn KEIN Passwort eingegeben wurde, prüfen wir, ob es ein privilegierter "Fast Login" ist.
        if (string.IsNullOrWhiteSpace(Password))
        {
            userSession = await LoginService.FastLoginAsync(Username);

            if (userSession == null)
            {
                ErrorMessage = "Für diesen Nutzer ist ein Passwort erforderlich (oder Personalnummer ungültig).";
                isLoading = false;
                StateHasChanged();
                return;
            }
        }
        else
        {
            // Normaler Login mit Passwort
            userSession = await LoginService.LoginAsync(Username, Password);

            if (userSession == null)
            {
                ErrorMessage = "Benutzername oder Passwort ist falsch!";
                Password = string.Empty;
                isLoading = false;
                StateHasChanged();
                return;
            }
        }

        // Login erfolgreich, erstelle ein temporäres Übertragungs-Token
        var token = TokenCache.GenerateToken(userSession, RememberMe);
        NavigationManager.NavigateTo($"/api/auth/process?token={token}", forceLoad: true);
    }
}

