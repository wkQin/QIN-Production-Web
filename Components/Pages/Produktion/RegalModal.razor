@using QIN_Production_Web.Data
@inject ProduktionslayoutService LayoutService
@inject NavigationManager NavManager

@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.85); z-index: 1050; display: flex !important; align-items: center;">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 98vw; width: 1800px;">
            <div class="modal-content border-0" style="background: rgba(15, 23, 42, 0.98); box-shadow: 0 0 40px rgba(255,144,0,0.25);">
                <!-- Header -->
                <div class="modal-header border-bottom border-light" style="border-bottom-color: rgba(255,255,255,0.1) !important;">
                    <h5 class="modal-title fw-bold text-white fs-3"><i class="fa-solid fa-server ms-1 me-3" style="color:#FF9000;"></i>Regaldetails @RangeTag</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="Close"></button>
                </div>

                <!-- Body -->
                <div class="modal-body p-4 overflow-x-auto" style="height: 80vh;">
                    @if (isLoading)
                    {
                        <div class="d-flex justify-content-center align-items-center h-100 flex-column text-white" style="min-height: 300px;">
                            <div class="spinner-border text-warning" style="width: 3rem; height: 3rem;" role="status"></div>
                            <span class="mt-3 fs-5">Lade Lagerplatz-Informationen aus der Datenbank...</span>
                        </div>
                    }
                    else if (RangeTag == "43-47")
                    {
                        <div class="d-flex gap-4" style="height: 100%; min-width: min-content;">
                            @foreach (var regalNum in new[] { 47, 46, 45, 44, 43 })
                            {
                                int offset = regalNum - 43;

                                <div class="d-flex flex-column h-100" style="background: #1e293b; border-radius: 8px; border: 4px solid #E65100; min-width: 750px; flex-shrink: 0;">
                                    <div class="flex-grow-1 d-flex flex-column p-2 gap-2" style="min-width: 0;">
                                        <!-- Layer 3 (Top) -->
                                        <div class="d-flex gap-2 flex-grow-1 align-items-stretch" style="flex-basis: 0; min-height: 0;">
                                            @for (int pOffset = 7; pOffset <= 9; pOffset++) { @RenderPlatz($"H4R{regalNum}P{(offset * 9) + pOffset}") }
                                        </div>

                                        <!-- Divider -->
                                        <div class="flex-shrink-0" style="height: 6px; background: #E65100; border-radius: 2px; width: 100%;"></div>

                                        <!-- Layer 2 (Middle) -->
                                        <div class="d-flex gap-2 flex-grow-1 align-items-stretch" style="flex-basis: 0; min-height: 0;">
                                            @for (int pOffset = 4; pOffset <= 6; pOffset++) { @RenderPlatz($"H4R{regalNum}P{(offset * 9) + pOffset}") }
                                        </div>

                                        <!-- Divider -->
                                        <div class="flex-shrink-0" style="height: 6px; background: #E65100; border-radius: 2px; width: 100%;"></div>

                                        <!-- Layer 1 (Bottom) -->
                                        <div class="d-flex gap-2 flex-grow-1 align-items-stretch" style="flex-basis: 0; min-height: 0;">
                                            @for (int pOffset = 1; pOffset <= 3; pOffset++) { @RenderPlatz($"H4R{regalNum}P{(offset * 9) + pOffset}") }
                                        </div>
                                    </div>
                                    
                                    <!-- Label Bottom -->
                                    <div class="p-2 text-center text-white fw-bold fs-5 flex-shrink-0" style="background: #E65100;">
                                        Regal @regalNum
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">Details für Regal-Tag '@RangeTag' sind noch nicht vollumfänglich visualisiert.</div>
                    }
                </div>

                <!-- Footer -->
                <div class="modal-footer border-top border-light" style="border-top-color: rgba(255,255,255,0.1) !important;">
                    <button type="button" class="btn btn-secondary fw-bold px-4" @onclick="Close">Schließen</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool IsVisible { get; set; }
    private string RangeTag { get; set; } = "";
    private bool isLoading = false;
    private Dictionary<string, PlatzInfo> platzInfos = new();

    public async Task ShowAsync(string rangeTag)
    {
        RangeTag = rangeTag;
        IsVisible = true;
        isLoading = true;
        StateHasChanged();

        if (rangeTag == "43-47")
        {
            var qrCodesToFetch = new List<string>();
            for (int r = 43; r <= 47; r++)
            {
                for (int p = 1; p <= 45; p++) qrCodesToFetch.Add($"H4R{r}P{p}");
            }
            platzInfos = await LayoutService.GetRegalInfosAsync(qrCodesToFetch);
        }
        else
        {
            platzInfos.Clear();
        }

        isLoading = false;
        StateHasChanged();
    }

    public void Close()
    {
        IsVisible = false;
        StateHasChanged();
    }

    private void OnSlotClick(PlatzInfo info)
    {
        if (!string.IsNullOrWhiteSpace(info?.PaletteCharge))
        {
            NavManager.NavigateTo($"/verwaltung/chargenanalyse?charge={Uri.EscapeDataString(info.PaletteCharge)}");
        }
    }

    private RenderFragment RenderPlatz(string qrCode) => __builder =>
    {
        platzInfos.TryGetValue(qrCode, out var info);
        info ??= new PlatzInfo { QRCode = qrCode };

        bool isEmpty = string.IsNullOrWhiteSpace(info.PaletteCharge) || info.SumAktuelleMenge <= 0;
        string bgClass = isEmpty ? "platz-empty" : "platz-occupied";
        
        <div class="flex-grow-1 platz-slot @bgClass rounded p-2 text-white shadow-sm overflow-hidden d-flex flex-column @(isEmpty ? "justify-content-center" : "") @(isEmpty ? "" : "clickable")" style="width: 32%; flex-basis: 0; min-width: 0;" @onclick="() => { if(!isEmpty) OnSlotClick(info); }">
            @if(isEmpty) {
                <div class="fw-bold d-flex flex-column align-items-center justify-content-center h-100 opacity-50 text-center" style="font-size: 0.85rem;">
                    <span>Leer</span>
                    <span class="mt-1 badge bg-dark border border-secondary">@qrCode.Split('P').Last()</span>
                </div>
            } else {
                <div class="fw-bold d-flex flex-column mb-1 w-100 flex-shrink-0" style="font-size: 0.90rem;">
                    <div class="d-flex justify-content-between align-items-start">
                        <span style="word-break: break-word; min-width: 0; flex: 1; line-height: 1.1;" title="@(info.PaletteCharge)">@(info.PaletteCharge)</span>
                        <span class="ms-1 badge bg-dark border border-secondary" title="Platz QR-Code">@qrCode.Split('P').Last()</span>
                    </div>
                </div>
                
                <hr class="my-1 border-white opacity-50 flex-shrink-0" />
                <div class="d-flex flex-column w-100 flex-grow-1" style="font-size: 0.70rem; line-height: 1.1; min-height: 0; overflow-y: auto;">
                    <span class="fw-bold text-light mb-1 flex-shrink-0">Artikel / Eingang:</span>
                    @if(info.Wareneingaenge.Count == 0) { <span class="flex-shrink-0">-</span> }
                    @foreach(var w in info.Wareneingaenge)
                    {
                        <span class="d-block mb-1 w-100 flex-shrink-0" style="word-break: break-word;" title="@w.Artikel">@w.Artikel (@w.Eingangsdatum.ToString("dd.MM.yy"))</span>
                    }
                    
                    <span class="fw-bold text-light mt-1 flex-shrink-0">Menge: <span class="text-white">@info.SumAktuelleMenge / @info.SumEchteMenge</span></span>
                    
                    <hr class="my-1 border-white opacity-25 flex-shrink-0" />
                    <span class="fw-bold text-light mt-1 mb-1 flex-shrink-0">Chargen (@info.Charges.Count):</span>
                    <div class="flex-grow-1" style="overflow-y: auto; overflow-x: hidden; min-height: 24px;">
                        @foreach(var c in info.Charges) {
                            <span class="d-block w-100" style="word-break: break-all;">@c</span>
                        }
                    </div>
                </div>
            }
        </div>
    };
}

<style>
    .platz-slot {
        min-width: 0;
        display: flex;
        flex-direction: column;
        transition: all 0.2s ease-in-out;
    }
    .platz-empty {
        background-color: #27272A;
        border: 1px solid rgba(255,255,255,0.05);
        color: #6c757d !important;
        opacity: 0.8;
    }
    .platz-occupied {
        background-color: #F57C00;
        border: 1px solid rgba(255,255,255,0.2);
    }
    .platz-occupied.clickable:hover {
        background-color: #E65100;
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(245, 124, 0, 0.4) !important;
        cursor: pointer;
    }
    .custom-scrollbar::-webkit-scrollbar {
        width: 3px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: rgba(0,0,0,0.1); 
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.3); 
        border-radius: 4px;
    }
</style>
