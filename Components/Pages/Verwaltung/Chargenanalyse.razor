@code {
    [Inject] private QIN_Production_Web.Data.ChargenanalyseService Service { get; set; } = default!;

    private string ActiveTab = "analyse";
    
    // Filter Bindings
    private QIN_Production_Web.Data.AnalyseFilters Filters = new();
    private List<string> ArtikelOptions = new();

    // Summary Properties
    private QIN_Production_Web.Data.AnalyseSummary Summary = new();

    // Data Lists
    private List<QIN_Production_Web.Data.AnalyseResult> Ergebnisse = new();
    private QIN_Production_Web.Data.AnalyseResult? SelectedResult;
    
    private QIN_Production_Web.Data.HeroData Hero = new();
    private List<QIN_Production_Web.Data.ThermoRow> ThermoData = new();
    private List<QIN_Production_Web.Data.UvRow> UvData = new();
    private List<QIN_Production_Web.Data.StanzenRow> StanzenData = new();
    private List<QIN_Production_Web.Data.EndkontrolleRow> EndkontrolleData = new();
    private QIN_Production_Web.Data.WareneingangRow? WareneingangData;

    private bool isSearching = false;
    private string ErrorMessage = "";

    private bool showThermo = false;
    private bool showUv = false;
    private bool showStanzen = false;
    private bool showEndkontrolle = false;

    private string sortColumn = "WareneingangDatum";
    private bool sortAscending = false;

    private MarkupString SortIcon(string column)
    {
        if (sortColumn != column) return new MarkupString("<i class='fa-solid fa-sort'></i>");
        return sortAscending ? new MarkupString("<i class='fa-solid fa-sort-up text-primary'></i>") : new MarkupString("<i class='fa-solid fa-sort-down text-primary'></i>");
    }

    private void SortTable(string column)
    {
        if (sortColumn == column) sortAscending = !sortAscending;
        else { sortColumn = column; sortAscending = true; }

        if (column == "Charge") Ergebnisse = sortAscending ? Ergebnisse.OrderBy(x => x.Charge).ToList() : Ergebnisse.OrderByDescending(x => x.Charge).ToList();
        else if (column == "FA_Nr") Ergebnisse = sortAscending ? Ergebnisse.OrderBy(x => x.FA_Nr).ToList() : Ergebnisse.OrderByDescending(x => x.FA_Nr).ToList();
        else if (column == "Artikel") Ergebnisse = sortAscending ? Ergebnisse.OrderBy(x => x.Artikel).ToList() : Ergebnisse.OrderByDescending(x => x.Artikel).ToList();
        else if (column == "WareneingangDatum") Ergebnisse = sortAscending ? Ergebnisse.OrderBy(x => x.WareneingangDatum).ToList() : Ergebnisse.OrderByDescending(x => x.WareneingangDatum).ToList();
        else if (column == "WareneingangCharge") Ergebnisse = sortAscending ? Ergebnisse.OrderBy(x => x.WareneingangCharge).ToList() : Ergebnisse.OrderByDescending(x => x.WareneingangCharge).ToList();
    }

    private void SetTab(string tab) {
        if (tab == "details" || tab == "wareneingang") {
            if (SelectedResult == null) return;
        }
        ActiveTab = tab;
    }

    [SupplyParameterFromQuery(Name = "charge")]
    public string? ChargeQuery { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Filters.DateVon = DateTime.Today.AddDays(-30);
        Filters.DateBis = DateTime.Today;
        
        if (!string.IsNullOrWhiteSpace(ChargeQuery))
        {
            Filters.Charge = ChargeQuery;
            Filters.DateVon = null; // Override dates to find the charge accurately anywhere
            Filters.DateBis = null;
        }

        try {
            // Fetch common Artikel options
            using (var conn = new Microsoft.Data.SqlClient.SqlConnection(QIN_Production_Web.Data.SqlManager.connectionString))
            {
                await conn.OpenAsync();
                var args = await Dapper.SqlMapper.QueryAsync<string>(conn, "SELECT DISTINCT ISNULL(Artikel, '') AS Artikel FROM dbo.Kunden WHERE Artikel IS NOT NULL AND Artikel != '' ORDER BY Artikel");
                ArtikelOptions = args.ToList();
            }

            await Suchen();

            // Auto-expand if linked from Layout
            if (!string.IsNullOrWhiteSpace(ChargeQuery) && Ergebnisse.Count > 0)
            {
                var match = Ergebnisse.FirstOrDefault(x => 
                    string.Equals(x.Charge, ChargeQuery, StringComparison.OrdinalIgnoreCase) || 
                    string.Equals(x.WareneingangCharge, ChargeQuery, StringComparison.OrdinalIgnoreCase))
                    ?? Ergebnisse.FirstOrDefault();
                    
                if (match != null)
                {
                    await ExpandDetails(match);
                    ActiveTab = "analyse"; // Keep user on overview tab initially
                }
            }
        } catch(Exception ex) {
            ErrorMessage = $"Init Error: {ex.Message}";
        }
    }

    private async Task Suchen()
    {
        isSearching = true;
        ErrorMessage = "";
        StateHasChanged();

        try {
            var (rows, summary) = await Service.GetChargenAsync(Filters);
            Ergebnisse = rows;
            Summary = summary;
        } catch(Exception ex) {
            ErrorMessage = $"Suchen Error: {ex.Message} | StackTrace: {ex.StackTrace}";
        }
        
        isSearching = false;
        StateHasChanged();
    }

    private void ClearFilters()
    {
        Filters = new QIN_Production_Web.Data.AnalyseFilters
        {
            DateVon = DateTime.Today.AddDays(-30),
            DateBis = DateTime.Today
        };
        Ergebnisse.Clear();
        Summary = new QIN_Production_Web.Data.AnalyseSummary();
    }

    private async Task ExpandDetails(QIN_Production_Web.Data.AnalyseResult result)
    {
        ErrorMessage = "";
        SelectedResult = result;
        ActiveTab = "details";
        StateHasChanged();

        try {
            // 1. Hero
            Hero = await Service.LoadHeroAsync(result.Charge);
            // 2. Details
            ThermoData = await Service.LoadThermoAsync(result.Charge);
            UvData = await Service.LoadUVAsync(result.Charge);
            StanzenData = await Service.LoadStanzenAsync(result.Charge);
            EndkontrolleData = await Service.LoadEndkontrolleAsync(result.Charge);
            
            // 3. Wareneingang
            if (Hero.IsWareneingangAvailable)
                WareneingangData = await Service.LoadWareneingangAsync(Hero.WE_ID);
            else
                WareneingangData = null;

        } catch(Exception ex) {
            ErrorMessage = $"Details Error: {ex.Message} \n {ex.StackTrace}";
        }

        StateHasChanged();
    }
}

