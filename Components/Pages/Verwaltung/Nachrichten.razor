@page "/nachrichten"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@using QIN_Production_Web.Data
@inject NachrichtenService MessageService
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Nachrichten</PageTitle>

<style>
    /* Premium Chat Aesthetics */
    .chat-container {
        max-height: 100vh;
        background: linear-gradient(135deg, var(--bg-main) 0%, var(--bg-card) 100%);
    }

    .glass-panel {
        background: var(--bg-card);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--border-color);
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
    }

    /* Custom Scrollbar */
    .scroll-area::-webkit-scrollbar {
        width: 6px;
    }
    .scroll-area::-webkit-scrollbar-track {
        background: transparent;
    }
    .scroll-area::-webkit-scrollbar-thumb {
        background-color: var(--border-color);
        border-radius: 10px;
    }

    /* Contact List Animations */
    .contact-item {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border-left: 3px solid transparent;
    }
    .contact-item:hover {
        background: var(--border-color) !important;
        transform: translateX(4px);
    }
    .contact-item.active {
        background: rgba(59, 130, 246, 0.1) !important;
        border-left: 3px solid #3b82f6;
    }

    /* Pulsing Online Indicator */
    .status-dot {
        box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7);
        animation: pulse-green 2s infinite;
    }
    @@keyframes pulse-green {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(34, 197, 94, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
    }

    /* Chat Bubbles with Tails */
    .message-bubble {
        position: relative;
        padding: 12px 16px;
        border-radius: 18px;
        font-size: 0.95rem;
        line-height: 1.4;
        max-width: 80%;
        animation: slide-up 0.3s ease-out;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
    @@keyframes slide-up {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .msg-mine {
        background: linear-gradient(135deg, #2563eb, #3b82f6);
        color: white;
        border-bottom-right-radius: 4px;
    }
    .msg-mine::after {
        content: '';
        position: absolute;
        bottom: 0;
        right: -6px;
        width: 12px;
        height: 12px;
        background: #3b82f6;
        border-bottom-left-radius: 100%;
        border-right: 6px solid var(--bg-card);
        z-index: -1;
    }

    .msg-theirs {
        background: rgba(51, 65, 85, 0.9);
        color: #f1f5f9;
        border-bottom-left-radius: 4px;
    }
    .msg-theirs::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: -6px;
        width: 12px;
        height: 12px;
        background: rgba(51, 65, 85, 0.9);
        border-bottom-right-radius: 100%;
        border-left: 6px solid var(--bg-card);
        z-index: -1;
    }

    /* Auto-expanding Input */
    .chat-input {
        resize: none;
        overflow-y: hidden;
        min-height: 48px;
        max-height: 120px;
        line-height: 1.5;
        border-radius: 24px;
        transition: border-color 0.2s;
    }
    .chat-input:focus {
        border-color: #3b82f6 !important;
        box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.25) !important;
    }

    /* Emoji Bar */
    .emoji-btn {
        transition: transform 0.2s;
        cursor: pointer;
        font-size: 1.25rem;
    }
    .emoji-btn:hover {
        transform: scale(1.28);
    }
</style>

<div class="chat-container container-fluid py-3 min-vh-100 d-flex flex-column h-100">
                
    <div class="row flex-grow-1 overflow-hidden g-3 h-100">
        <!-- LEFT PANEL: CONVERSATIONS -->
        <div class="col-md-4 d-flex flex-column h-100">
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger p-2 small mb-2 text-wrap shadow" style="white-space: pre-wrap;"><i class="fa-solid fa-triangle-exclamation me-2"></i>@ErrorMessage</div>
            }
            <div class="card glass-panel rounded-4 d-flex flex-column h-100 border-0">
                
                <!-- Sidebar Header -->
                <div class="card-header border-0 bg-transparent p-4 pb-2 d-flex align-items-center justify-content-between">
                    <h4 class="mb-0 text-white fw-bold d-flex align-items-center">
                        <div class="bg-primary bg-gradient p-2 rounded-3 me-3 shadow-sm d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;">
                            <i class="fa-solid fa-paper-plane text-white fs-5"></i>
                        </div>
                        Chat
                    </h4>
                    <button class="btn btn-link text-secondary p-0 hover-primary transition"><i class="fa-solid fa-pen-to-square fs-5"></i></button>
                </div>

                <!-- Search Box -->
                <div class="px-4 py-3">
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-dark bg-opacity-50 border-0 text-secondary rounded-start-pill ps-3">
                            <i class="fa-solid fa-search"></i>
                        </span>
                        <input type="text" class="form-control bg-dark bg-opacity-50 border-0 text-white rounded-end-pill shadow-none" 
                               placeholder="Kollegen suchen..." 
                               @bind="SearchText" 
                               @bind:event="oninput" />
                    </div>
                </div>

                <!-- Contact List -->
                <div class="card-body p-2 scroll-area overflow-auto flex-grow-1" style="max-height: calc(100vh - 200px);">
                    @if (IsLoadingContacts)
                    {
                        <div class="text-center p-4">
                            <div class="spinner-border text-primary spinner-border-sm"></div>
                        </div>
                    }
                    else if (!FilteredConversations.Any())
                    {
                        <div class="text-center text-secondary mt-5 p-3 small">Keine Chats gefunden.</div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush rounded-3">
                            @foreach (var conv in FilteredConversations)
                            {
                                bool isSelected = SelectedUser == conv.DisplayName;
                                <li class="list-group-item bg-transparent border-0 mb-1 p-0 rounded-4 overflow-hidden">
                                    <button class="contact-item btn w-100 text-start d-flex align-items-center p-3 border-0 @(isSelected ? "active" : "")" 
                                            @onclick="() => SelectUserAsync(conv.DisplayName)">
                                        
                                        <!-- Avatar -->
                                        <div class="position-relative me-3 shadow-sm">
                                            <div class="rounded-circle bg-gradient text-white d-flex align-items-center justify-content-center fw-bold" 
                                                 style="width: 50px; height: 50px; font-size: 1.2rem; background: @(isSelected ? "linear-gradient(135deg, #3b82f6, #60a5fa)" : "linear-gradient(135deg, #475569, #64748b)");">
                                                @conv.Initials
                                            </div>
                                            <!-- Online Indicator -->
                                            <span class="position-absolute bottom-0 end-0 p-1 border border-2 border-dark rounded-circle 
                                                  @(conv.IsOnline ? "bg-success status-dot" : "bg-secondary")" 
                                                  style="width: 14px; height: 14px; transform: translate(-2px, -2px);">
                                            </span>
                                        </div>

                                        <!-- Name & Preview -->
                                        <div class="flex-grow-1 min-w-0">
                                            <div class="d-flex justify-content-between align-items-baseline mb-1">
                                                <h6 class="mb-0 text-white fw-bold text-truncate" style="max-width: 130px; letter-spacing: 0.3px;">@conv.DisplayName</h6>
                                                <small class="text-secondary fw-semibold" style="font-size: 0.70rem;">@conv.FormattedTime</small>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center">
                                                <p class="mb-0 text-truncate small @(conv.UnreadCount > 0 ? "text-white fw-bold" : "text-secondary")" style="max-width: 170px;">
                                                    @if (string.IsNullOrEmpty(conv.LastMessagePreview))
                                                    {
                                                        <text>Nachricht senden...</text>
                                                    }
                                                    else
                                                    {
                                                        if (conv.LastMessageSender != null && conv.LastMessageSender.Trim().Equals(CurrentUser.Trim(), StringComparison.OrdinalIgnoreCase))
                                                        {
                                                            <span class="text-white-50">Du: </span>
                                                        }
                                                        @conv.LastMessagePreview
                                                    }
                                                </p>
                                                @if (conv.UnreadCount > 0)
                                                {
                                                    <span class="badge bg-primary rounded-pill shadow">@conv.UnreadCount</span>
                                                }
                                            </div>
                                        </div>
                                    </button>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <!-- RIGHT PANEL: CHAT HISTORY -->
        <div class="col-md-8 d-flex flex-column h-100">
            <div class="card glass-panel rounded-4 border-0 d-flex flex-column h-100 overflow-hidden shadow-lg position-relative">
                
                @if (string.IsNullOrEmpty(SelectedUser))
                {
                    <div class="card-body d-flex flex-column align-items-center justify-content-center h-100 text-secondary">
                        <div class="position-relative mb-4">
                            <i class="fa-solid fa-comment-dots fa-5x text-secondary opacity-25"></i>
                            <div class="spinner-grow text-primary position-absolute top-0 start-100 translate-middle opacity-50" style="width: 1.5rem; height: 1.5rem;" role="status"></div>
                        </div>
                        <h3 class="fw-bold text-white mb-2">QIN Messenger</h3>
                        <p class="text-center text-secondary" style="max-width: 300px;">Wähle einen Kontakt aus der linken Liste, um eine verschlüsselte Unterhaltung zu starten.</p>
                    </div>
                }
                else
                {
                    var selectedConvInfo = Conversations.FirstOrDefault(c => c.DisplayName == SelectedUser);
                    bool isOnline = selectedConvInfo?.IsOnline ?? false;

                    <!-- Chat Header -->
                    <div class="card-header border-bottom border-dark bg-dark bg-opacity-25 p-3 px-4 d-flex align-items-center shadow-sm z-3">
                        <div class="rounded-circle text-white d-flex align-items-center justify-content-center fw-bold me-3 shadow-sm" 
                             style="width: 45px; height: 45px; background: linear-gradient(135deg, #3b82f6, #60a5fa); font-size: 1.1rem;">
                            @(selectedConvInfo?.Initials ?? "?")
                        </div>
                        <div class="flex-grow-1">
                            <h5 class="mb-0 text-white fw-bold">@SelectedUser</h5>
                            <small class="@(isOnline ? "text-success" : "text-secondary") fw-semibold d-flex align-items-center" style="font-size: 0.8rem;">
                                <span class="rounded-circle d-inline-block me-1 @(isOnline ? "bg-success status-dot" : "bg-secondary")" style="width: 8px; height: 8px;"></span>
                                @(isOnline ? "Online" : $"Zuletzt online: {(selectedConvInfo?.LastSeenDate.HasValue == true ? selectedConvInfo.LastSeenDate.Value.ToString("dd.MM.yyyy HH:mm") : "Unbekannt")}")
                            </small>
                        </div>
                    </div>

                    <!-- Chat Messages Area -->
                    <div class="card-body p-4 scroll-area overflow-auto flex-grow-1 d-flex flex-column position-relative" id="chatScrollArea" style="max-height: calc(100vh - 220px);">
                        
                        <!-- Watermark -->
                        <div class="position-absolute top-50 start-50 translate-middle opacity-10 pointer-events-none" style="z-index: 0;">
                            <i class="fa-solid fa-industry fa-10x"></i>
                        </div>

                        <div class="z-1">
                            @if (IsLoadingMessages)
                            {
                                <div class="text-center mt-4">
                                    <div class="spinner-border text-primary" role="status"></div>
                                </div>
                            }
                            else
                            {
                                var groupedMessages = Messages.Where(m => m.Datum.HasValue).GroupBy(m => m.Datum!.Value.Date);
                                foreach (var group in groupedMessages)
                                {
                                    <!-- Date Separator -->
                                    <div class="d-flex justify-content-center my-4">
                                        <span class="badge bg-dark bg-opacity-75 text-secondary px-3 py-2 rounded-pill shadow-sm fw-normal border border-secondary" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                                            @if (group.Key == DateTime.Today) { <text>HEUTE</text> }
                                            else if (group.Key == DateTime.Today.AddDays(-1)) { <text>GESTERN</text> }
                                            else { @group.Key.ToString("dd. MMMM yyyy").ToUpper() }
                                        </span>
                                    </div>

                                    foreach (var msg in group)
                                    {
                                        bool isMine = !string.IsNullOrEmpty(msg.Sender) && 
                                                      msg.Sender.Trim().Equals(CurrentUser.Trim(), StringComparison.OrdinalIgnoreCase);

                                        <div class="d-flex mb-3 @(isMine ? "justify-content-end" : "justify-content-start")">
                                            <div class="message-bubble @(isMine ? "msg-mine" : "msg-theirs")">
                                                
                                                <div style="word-wrap: break-word; white-space: pre-wrap;">@msg.Text</div>
                                                
                                                <div class="mt-1 d-flex @(isMine ? "justify-content-end" : "justify-content-start") align-items-center" style="font-size: 0.65rem; opacity: 0.8;">
                                                    <span class="me-1 fw-bold">@(msg.Datum.HasValue ? msg.Datum.Value.ToString("HH:mm") : "")</span>
                                                    @if (isMine)
                                                    {
                                                        <i class="fa-solid fa-check-double @(msg.Gelesen ? "text-info" : "text-light opacity-50")" style="font-size: 0.60rem;"></i>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            }
                        </div>
                    </div>

                    <!-- Chat Input Footer -->
                    <div class="card-footer border-top border-dark bg-dark bg-opacity-50 p-3 px-4 z-3">
                        <!-- Quick Emoji Bar -->
                        <div class="d-flex gap-3 mb-2 px-2 text-white opacity-75">
                            <span class="emoji-btn" @onclick='() => AddEmoji("👍")'>👍</span>
                            <span class="emoji-btn" @onclick='() => AddEmoji("🔥")'>🔥</span>
                            <span class="emoji-btn" @onclick='() => AddEmoji("😂")'>😂</span>
                            <span class="emoji-btn" @onclick='() => AddEmoji("🎉")'>🎉</span>
                            <span class="emoji-btn" @onclick='() => AddEmoji("✅")'>✅</span>
                            <span class="emoji-btn" @onclick='() => AddEmoji("❌")'>❌</span>
                        </div>
                        <div class="d-flex align-items-end gap-2 bg-dark rounded-4 p-1 px-2 border border-secondary shadow-sm">
                            <textarea class="form-control chat-input bg-transparent border-0 text-white shadow-none p-2 w-100 ms-2" 
                                      placeholder="Schreibe eine Nachricht..." 
                                      @bind="NewMessageText" 
                                      @bind:event="oninput" 
                                      @onkeydown="HandleKeyDown"
                                      id="msgInput"
                                      onkeyup="this.style.height = '';this.style.height = this.scrollHeight + 'px'"></textarea>
                                      
                            <button class="btn btn-primary rounded-circle shadow-sm flex-shrink-0 mb-1 d-flex align-items-center justify-content-center" 
                                    style="width: 42px; height: 42px;"
                                    @onclick="SendMsgAsync" 
                                    disabled="@string.IsNullOrWhiteSpace(NewMessageText)">
                                <i class="fa-solid fa-paper-plane"></i>
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    window.scrollToBottom = function (elementId) {
        var element = document.getElementById(elementId);
        if (element) {
            element.scrollTop = element.scrollHeight;
        }
    }
</script>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private string CurrentUser = string.Empty;
    private string SelectedUser = string.Empty;
    private string SearchText = string.Empty;
    private string NewMessageText = string.Empty;

    private List<ConversationDto> Conversations = new();
    private List<ConversationDto> FilteredConversations => string.IsNullOrWhiteSpace(SearchText) 
        ? Conversations 
        : Conversations.Where(c => c.DisplayName.Contains(SearchText, StringComparison.OrdinalIgnoreCase)).ToList();

    private List<MessageDto> Messages = new();

    private bool IsLoadingContacts = true;
    private bool IsLoadingMessages = false;
    private bool shouldScrollToBottom = false;

    private System.Threading.Timer? _pollTimer;

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            CurrentUser = authState.User?.Identity?.Name?.Trim() ?? string.Empty;
        }

        if (!string.IsNullOrEmpty(CurrentUser))
        {
            await LoadConversationsAsync();

            // Start polling every 5 seconds (5000ms) like WPF DispatcherTimer
            _pollTimer = new System.Threading.Timer(OnPollTimerTicked, null, 5000, 5000);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            string newUser = authState.User?.Identity?.Name?.Trim() ?? string.Empty;

            if (newUser != CurrentUser && !string.IsNullOrEmpty(newUser))
            {
                // Another tab logged into a different account, update this tab immediately!
                CurrentUser = newUser;
                SelectedUser = string.Empty; 
                Messages.Clear();
                await LoadConversationsAsync();
                StateHasChanged();
            }
        }
    }

    private async void OnPollTimerTicked(object? state)
    {
        // Must use InvokeAsync to update UI thread from background timer
        await InvokeAsync(async () =>
        {
            await LoadConversationsAsync(silent: true);
            if (!string.IsNullOrEmpty(SelectedUser))
            {
                await LoadMessagesAsync(silent: true);
            }
            StateHasChanged();
        });
    }

    private string? ErrorMessage = null;

    private async Task LoadConversationsAsync(bool silent = false)
    {
        if (!silent) IsLoadingContacts = true;
        ErrorMessage = null;
        try
        {
            var data = await MessageService.GetConversationsAsync(CurrentUser);
            Conversations = data.ToList();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Fehler beim Laden der Kontakte:\n{ex.Message}";
        }
        finally
        {
            if (!silent) IsLoadingContacts = false;
        }
    }

    private async Task SelectUserAsync(string? userName)
    {
        if (string.IsNullOrEmpty(userName)) return;
        if (SelectedUser == userName) return;
        SelectedUser = userName;
        await LoadMessagesAsync();
        shouldScrollToBottom = true;
    }

    private async Task LoadMessagesAsync(bool silent = false)
    {
        if (string.IsNullOrEmpty(SelectedUser)) return;

        if (!silent) IsLoadingMessages = true;
        try
        {
            int oldCount = Messages.Count;
            var data = await MessageService.GetMessagesAsync(CurrentUser, SelectedUser);
            Messages = data.ToList();

            // If we received new messages via polling, scroll to bottom
            if (silent && Messages.Count > oldCount)
            {
                shouldScrollToBottom = true;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Fehler beim Laden des Chats:\n{ex.Message}";
        }
        finally
        {
            if (!silent) IsLoadingMessages = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            if (!string.IsNullOrWhiteSpace(NewMessageText))
            {
                await SendMsgAsync();
            }
        }
    }

    private void AddEmoji(string emoji)
    {
        NewMessageText += emoji;
    }

    private async Task SendMsgAsync()
    {
        if (string.IsNullOrWhiteSpace(NewMessageText) || string.IsNullOrEmpty(SelectedUser)) return;

        string txt = NewMessageText.Trim();
        NewMessageText = string.Empty; // clear input fast

        // Reset textarea height
        await JS.InvokeVoidAsync("eval", "document.getElementById('msgInput').style.height = '48px';");

        bool saved = await MessageService.SendMessageAsync(CurrentUser, SelectedUser, txt);
        if (saved)
        {
            await LoadMessagesAsync(silent: true);
            await LoadConversationsAsync(silent: true);
            shouldScrollToBottom = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (shouldScrollToBottom)
        {
            shouldScrollToBottom = false;
            await ScrollToBottom();
        }
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("scrollToBottom", "chatScrollArea");
        }
        catch { /* ignore JS interop errors during disposal */ }
    }

    public void Dispose()
    {
        _pollTimer?.Dispose();
    }
}

