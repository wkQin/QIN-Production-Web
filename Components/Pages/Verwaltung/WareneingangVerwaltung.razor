@page "/verwaltung/wareneingang"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using QIN_Production_Web.Data
@inject VerwaltungWareneingangService WEService
@inject IJSRuntime JS
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<PageTitle>Wareneingang Verwaltung</PageTitle>

<div class="container-fluid py-4 min-vh-100 bg-dark">
    <!-- Header -->
    <div class="p-4 mb-4 rounded-4 shadow-lg border border-secondary" style="background: var(--bg-card); backdrop-filter: blur(10px);">
        <div class="d-flex align-items-center">
            <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3">
                <i class="fa-solid fa-truck-loading fa-2x text-success"></i>
            </div>
            <div>
                <h2 class="text-white mb-1 fw-bold">Wareneingang Verwaltung</h2>
                <p class="text-secondary mb-0 small">Zentrale Verwaltung für gebuchte und offene Wareneingänge inklusive Chargen-Zuteilung</p>
            </div>
        </div>
        
        <hr class="border-secondary my-4" />
        
        <div class="row g-3 align-items-center">
            <div class="col-md-5">
                <ul class="nav nav-pills w-100 p-1 mx-0 rounded-3 border border-secondary d-flex" style="background: var(--bg-hover);">
                    <li class="nav-item flex-fill text-center">
                        <button class="nav-link w-100 @(ActiveFilter == "Alle" ? "active bg-primary" : "text-white") fw-bold rounded-2 px-3 py-2" 
                                @onclick='() => ChangeFilter("Alle")'>Alle</button>
                    </li>
                    <li class="nav-item flex-fill text-center">
                        <button class="nav-link w-100 @(ActiveFilter == "Gebucht" ? "active bg-success" : "text-white") fw-bold rounded-2 px-3 py-2" 
                                @onclick='() => ChangeFilter("Gebucht")'>Gebucht</button>
                    </li>
                    <li class="nav-item flex-fill text-center">
                        <button class="nav-link w-100 @(ActiveFilter == "Nicht Gebucht" ? "active bg-warning text-dark" : "text-white") fw-bold rounded-2 px-3 py-2" 
                                @onclick='() => ChangeFilter("Nicht Gebucht")'>Nicht Gebucht</button>
                    </li>
                </ul>
            </div>
            <div class="col-md-5">
                 <div class="input-group">
                    <span class="input-group-text bg-secondary border-secondary text-white"><i class="fa-solid fa-search"></i></span>
                    <input type="text" class="form-control border-secondary text-white bg-dark" placeholder="Suche in Liste..." 
                           @bind-value="SearchQuery" @bind-value:event="oninput" @onkeyup="FilterLocally" />
                </div>
            </div>
            <div class="col-md-2 text-end">
                <button class="btn btn-outline-light w-100 fw-bold" @onclick="() => LoadWEAsync()">
                    <i class="fa-solid fa-rotate-right me-1"></i> Refresh
                </button>
            </div>
        </div>
    </div>

    <!-- Main Wareneingang Table -->
    <div class="card bg-dark border-secondary shadow-lg rounded-4 overflow-hidden mb-4">
        <div class="card-header border-secondary bg-dark text-white fw-bold d-flex justify-content-between align-items-center">
            <span><i class="fa-solid fa-list me-2"></i> Wareneingänge</span>
            <span class="badge bg-secondary rounded-pill">@(FilteredWERows.Count) Einträge</span>
        </div>
        <div class="card-body p-0">
            @if (IsLoadingWE)
            {
                <div class="text-center p-5">
                    <div class="spinner-border text-success" role="status">
                        <span class="visually-hidden">Lade Daten...</span>
                    </div>
                </div>
            }
            else if (!FilteredWERows.Any())
            {
                <div class="text-center p-5 text-secondary">
                    Keine Wareneingänge gefunden.
                </div>
            }
            else
            {
                <div class="table-responsive" style="max-height: 450px; overflow-y: auto;">
                    <table id="weVerwaltungTable" class="table table-dark table-hover table-striped mb-0 text-nowrap align-middle">
                        <thead class="table-dark sticky-top" style="background-color: var(--bg-hover);">
                            <tr>
                                <th class="text-center" style="width: 100px;">Aktionen</th>
                                <th style="cursor: pointer;" @onclick='() => SortWE("EBEPos")'>EBE / Pos @GetSortIcon("EBEPos")</th>
                                <th style="cursor: pointer;" @onclick='() => SortWE("Gebucht")'>Gebucht @GetSortIcon("Gebucht")</th>
                                <th style="cursor: pointer;" @onclick='() => SortWE("Lieferant")'>Lieferant @GetSortIcon("Lieferant")</th>
                                <th style="cursor: pointer;" @onclick='() => SortWE("Artikel")'>Artikel @GetSortIcon("Artikel")</th>
                                <th class="text-info" style="cursor: pointer;" @onclick='() => SortWE("LS_Nr")'>LS Nr @GetSortIcon("LS_Nr")</th>
                                <th style="cursor: pointer;" @onclick='() => SortWE("Menge")'>Menge @GetSortIcon("Menge")</th>
                                <th style="cursor: pointer;" @onclick='() => SortWE("Chargen")'>Chargen @GetSortIcon("Chargen")</th>
                                <th style="cursor: pointer;" @onclick='() => SortWE("Datum")'>Datum @GetSortIcon("Datum")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in FilteredWERows)
                            {
                                bool isSelected = row.ID == SelectedWE?.ID;
                                <tr class="@(isSelected ? "table-active border-start border-4 border-info" : "")" 
                                    style="cursor: pointer;" @onclick="() => SelectWEAsync(row)">
                                    <td class="text-center" @onclick:stopPropagation="true">
                                        <div class="btn-group">
                                            @if (row.Gebucht != true)
                                            {
                                                <button class="btn btn-sm btn-outline-success text-white" @onclick="() => ToggleBuchungAsync(row)" title="Buchen">
                                                    <i class="fa-solid fa-check"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-warning text-white" @onclick="() => ToggleBuchungAsync(row)" title="Buchung stornieren">
                                                    <i class="fa-solid fa-rotate-left"></i>
                                                </button>
                                            }
                                            <button class="btn btn-sm btn-outline-info text-white" @onclick="() => OpenWEModal(row)" title="Bearbeiten">
                                                <i class="fa-solid fa-pen"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteWEAsync(row.ID)" title="Löschen">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </div>
                                    </td>
                                    <td class="fw-bold text-warning">@FormatEbePos(row)</td>
                                    <td>
                                        @if (row.Gebucht == true)
                                        {
                                            <span class="badge bg-success"><i class="fa-solid fa-check me-1"></i> JA</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark"><i class="fa-solid fa-xmark me-1"></i> NEIN</span>
                                        }
                                    </td>
                                    <td>@row.Lieferant</td>
                                    <td>@row.Artikel</td>
                                    <td class="fw-bold text-info">@row.LS_Nr</td>
                                    <td>@row.Menge</td>
                                    <td>
                                        <span class="badge bg-secondary rounded-pill px-2">@row.Chargen</span>
                                    </td>
                                    <td>@row.Eingangsdatum</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Chargen Table for selected Wareneingang -->
    @if (SelectedWE != null)
    {
        <div class="card bg-dark border-info shadow-lg rounded-4 overflow-hidden mb-4 animate__animated animate__fadeIn">
            <div class="card-header border-info bg-dark text-white fw-bold d-flex justify-content-between align-items-center">
                <span>
                    <i class="fa-solid fa-boxes-stacked me-2 text-info"></i> Chargen für Lieferschein: <span class="text-info">@SelectedWE.LS_Nr</span>
                </span>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-secondary rounded-pill px-3 py-2">
                        Gesamt Laufmeter/Stk: @ChargenRows.Sum(x => x.MengeAnzeige)
                    </span>
                    <button class="btn btn-sm btn-info fw-bold text-dark" @onclick="OpenAddChargeModal">
                        <i class="fa-solid fa-plus me-1"></i> Neue Charge
                    </button>
                </div>
            </div>
            <div class="card-body p-0">
                @if (IsLoadingChargen)
                {
                    <div class="text-center p-4">
                        <div class="spinner-border spinner-border-sm text-info" role="status"></div> Lade Chargen...
                    </div>
                }
                else if (!ChargenRows.Any())
                {
                    <div class="text-center p-4 text-secondary">
                        Keine Chargen zu diesem Lieferschein hinterlegt.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table id="weChargenTable" class="table table-dark table-hover mb-0 text-nowrap align-middle">
                            <thead class="table-dark" style="background-color: var(--bg-hover);">
                                <tr>
                                    <th style="width: 80px;">Aktionen</th>
                                    <th style="cursor: pointer;" @onclick='() => SortChargen("Charge")'>Charge Text @GetChargeSortIcon("Charge")</th>
                                    <th style="cursor: pointer;" @onclick='() => SortChargen("Menge")'>Laufmeter/Stk @GetChargeSortIcon("Menge")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var charge in ChargenRows)
                                {
                                    <tr>
                                        <td>
                                            <div class="btn-group">
                                                <button class="btn btn-sm btn-outline-info text-white" @onclick="() => OpenChargeModal(charge)" title="Bearbeiten">
                                                    <i class="fa-solid fa-pen"></i>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteChargeAsync(charge.ID)" title="Löschen">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            </div>
                                        </td>
                                        <td class="fw-bold text-white">@charge.Charge</td>
                                        <td class="text-info fw-bold">@charge.MengeAnzeige</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

<WEEditModal @ref="weModal" OnSave="SaveWEAsync" />
<ChargeEditModal @ref="chargeModal" OnSave="SaveChargeAsync" />

@code {
    private string ActiveFilter = "Alle";
    private string SearchQuery = "";
    private string SortColumn = "Datum";
    private bool SortAscending = false;
    private string ChargeSortColumn = "Charge";
    private bool ChargeSortAscending = true;
    
    private bool IsLoadingWE = false;
    private bool IsLoadingChargen = false;

    private List<WareneingangEntry> AllWERows = new();
    private List<WareneingangEntry> FilteredWERows = new();
    private WareneingangEntry? SelectedWE;

    private List<ChargeEntry> ChargenRows = new();

    private WEEditModal weModal = default!;
    private ChargeEditModal chargeModal = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadWEAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("makeTableResizable", "weVerwaltungTable");

        if (SelectedWE != null && ChargenRows.Any())
        {
            await JS.InvokeVoidAsync("makeTableResizable", "weChargenTable");
        }
    }

    private async Task ChangeFilter(string filter)
    {
        if (ActiveFilter == filter) return;
        ActiveFilter = filter;
        await LoadWEAsync();
    }

    private void FilterLocally()
    {
        if (string.IsNullOrWhiteSpace(SearchQuery))
        {
            FilteredWERows = AllWERows;
        }
        else
        {
            var q = SearchQuery.ToLower();
            FilteredWERows = AllWERows.Where(x => 
                (x.LS_Nr != null && x.LS_Nr.ToLower().Contains(q)) ||
                (x.Lieferant != null && x.Lieferant.ToLower().Contains(q)) ||
                (x.Artikel != null && x.Artikel.ToLower().Contains(q)) ||
                (x.Eingangsdatum != null && x.Eingangsdatum.ToLower().Contains(q)) ||
                FormatEbePos(x).ToLower().Contains(q)
            ).ToList();
        }

        ApplyWESort();
    }

    private async Task LoadWEAsync(int? preserveSelectedId = null)
    {
        IsLoadingWE = true;
        if (preserveSelectedId == null)
        {
            SelectedWE = null;
        }
        StateHasChanged();

        try
        {
            var raw = await WEService.GetWareneingangsAsync(ActiveFilter);
            AllWERows = raw.ToList();
            FilterLocally();

            if (preserveSelectedId.HasValue)
            {
                SelectedWE = FilteredWERows.FirstOrDefault(x => x.ID == preserveSelectedId.Value)
                    ?? AllWERows.FirstOrDefault(x => x.ID == preserveSelectedId.Value);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"WE Load Error: {ex.Message}");
        }
        finally
        {
            IsLoadingWE = false;
            StateHasChanged();
        }
    }

    private async Task SelectWEAsync(WareneingangEntry we)
    {
        SelectedWE = we;
        await LoadChargenAsync(we.ID);
    }

    private async Task LoadChargenAsync(int weId)
    {
        IsLoadingChargen = true;
        StateHasChanged();
        try
        {
            var res = await WEService.GetChargenForWareneingangAsync(weId);
            ChargenRows = res.ToList();
            ApplyChargeSort();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Chargen Load Error: {ex.Message}");
        }
        finally
        {
            IsLoadingChargen = false;
            StateHasChanged();
        }
    }

    // --- Wareneingang Actions ---

    private async Task ToggleBuchungAsync(WareneingangEntry row)
    {
        try
        {
            IsLoadingWE = true;
            row.Gebucht = (row.Gebucht == true) ? false : true;
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            string userName = authState.User.Identity?.Name ?? "Verwaltung";
            bool succ = await WEService.UpdateWareneingangAsync(row, userName);
             
            if (succ) {
                await LoadWEAsync(row.ID);
                if (SelectedWE != null) await LoadChargenAsync(SelectedWE.ID);
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Fehler beim Verbuchen/Stornieren:\n{ex.Message}");
            IsLoadingWE = false;
        }
    }

    private void OpenWEModal(WareneingangEntry row)
    {
        weModal.ShowAsync(row);
    }

    private async Task SaveWEAsync(WareneingangEntry updated)
    {
        try
        {
            IsLoadingWE = true;
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            string userName = authState.User.Identity?.Name ?? "Verwaltung";
            bool succ = await WEService.UpdateWareneingangAsync(updated, userName);
            if (succ)
            {
                await LoadWEAsync(updated.ID);
                if (SelectedWE != null) await LoadChargenAsync(SelectedWE.ID);
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Fehler beim Speichern des WE:\n{ex.Message}");
        }
        finally
        {
            IsLoadingWE = false;
        }
    }

    private async Task DeleteWEAsync(int id)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Möchten Sie diesen gesamten Wareneingang (inkl. aller zugehörigen Chargen) unwiderruflich löschen?");
        if (confirmed)
        {
            try
            {
                IsLoadingWE = true;
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                string userName = authState.User.Identity?.Name ?? "Verwaltung";
                bool succ = await WEService.DeleteWareneingangAsync(id, userName);
                if (succ) await LoadWEAsync();
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("alert", $"Fehler: {ex.Message}");
                IsLoadingWE = false;
            }
        }
    }

    // --- Chargen Actions ---

    private void OpenChargeModal(ChargeEntry charge)
    {
        chargeModal.ShowAsync(charge);
    }

    private void OpenAddChargeModal()
    {
        if (SelectedWE == null) return;
        var newChg = new ChargeEntry { ID = 0, Wareneingang_ID = SelectedWE.ID };
        chargeModal.ShowAsync(newChg);
    }

    private async Task SaveChargeAsync(ChargeEntry edited)
    {
        try
        {
            IsLoadingChargen = true;
            bool succ = false;
            
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            string userName = authState.User.Identity?.Name ?? "Verwaltung";

            if (edited.ID == 0)
            {
                succ = await WEService.AddChargeAsync(edited, userName);
            }
            else
            {
                succ = await WEService.UpdateChargeAsync(edited, userName);
            }
            
            if (succ && SelectedWE != null)
            {
                await LoadChargenAsync(SelectedWE.ID);
                await LoadWEAsync();
            }
        }
        catch(Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Fehler beim Speichern der Charge:\n{ex.Message}");
        }
        finally
        {
            IsLoadingChargen = false;
            StateHasChanged();
        }
    }

    private async Task DeleteChargeAsync(int chargeId)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Soll diese Charge gelöscht werden?");
        if (confirmed)
        {
            try
            {
                IsLoadingChargen = true;
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                string userName = authState.User.Identity?.Name ?? "Verwaltung";
                
                bool succ = await WEService.DeleteChargeAsync(chargeId, userName);
                if (succ && SelectedWE != null)
                {
                    await LoadChargenAsync(SelectedWE.ID);
                    await LoadWEAsync(SelectedWE.ID);
                }
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("alert", $"Fehler: {ex.Message}");
                IsLoadingChargen = false;
            }
        }
    }

    private string FormatEbePos(WareneingangEntry row)
    {
        var ebe = row.EBE_NR?.Trim();
        var pos = row.Pos?.Trim();

        if (string.IsNullOrWhiteSpace(ebe) && string.IsNullOrWhiteSpace(pos)) return "-";
        if (string.IsNullOrWhiteSpace(pos)) return ebe ?? "-";
        if (string.IsNullOrWhiteSpace(ebe)) return pos ?? "-";

        return $"{ebe}-{pos}";
    }

    private void SortWE(string column)
    {
        if (SortColumn == column)
        {
            SortAscending = !SortAscending;
        }
        else
        {
            SortColumn = column;
            SortAscending = column is "Lieferant" or "Artikel" or "LS_Nr" or "EBEPos";
        }

        ApplyWESort();
    }

    private void ApplyWESort()
    {
        IEnumerable<WareneingangEntry> sorted = SortColumn switch
        {
            "Gebucht" => SortAscending ? FilteredWERows.OrderBy(x => x.Gebucht == true) : FilteredWERows.OrderByDescending(x => x.Gebucht == true),
            "Lieferant" => SortAscending ? FilteredWERows.OrderBy(x => x.Lieferant) : FilteredWERows.OrderByDescending(x => x.Lieferant),
            "Artikel" => SortAscending ? FilteredWERows.OrderBy(x => x.Artikel) : FilteredWERows.OrderByDescending(x => x.Artikel),
            "LS_Nr" => SortAscending ? FilteredWERows.OrderBy(x => x.LS_Nr) : FilteredWERows.OrderByDescending(x => x.LS_Nr),
            "EBEPos" => SortAscending ? FilteredWERows.OrderBy(x => FormatEbePos(x)) : FilteredWERows.OrderByDescending(x => FormatEbePos(x)),
            "Menge" => SortAscending ? FilteredWERows.OrderBy(x => ParseInt(x.Menge)) : FilteredWERows.OrderByDescending(x => ParseInt(x.Menge)),
            "Chargen" => SortAscending ? FilteredWERows.OrderBy(x => x.Chargen) : FilteredWERows.OrderByDescending(x => x.Chargen),
            _ => SortAscending
                ? FilteredWERows.OrderBy(x => HasValidDate(x.Eingangsdatum) ? 0 : 1).ThenBy(x => ParseDate(x.Eingangsdatum))
                : FilteredWERows.OrderBy(x => HasValidDate(x.Eingangsdatum) ? 0 : 1).ThenByDescending(x => ParseDate(x.Eingangsdatum))
        };

        FilteredWERows = sorted.ToList();
    }

    private void SortChargen(string column)
    {
        if (ChargeSortColumn == column)
        {
            ChargeSortAscending = !ChargeSortAscending;
        }
        else
        {
            ChargeSortColumn = column;
            ChargeSortAscending = column == "Charge";
        }

        ApplyChargeSort();
    }

    private void ApplyChargeSort()
    {
        IEnumerable<ChargeEntry> sorted = ChargeSortColumn switch
        {
            "Menge" => ChargeSortAscending ? ChargenRows.OrderBy(x => x.MengeAnzeige) : ChargenRows.OrderByDescending(x => x.MengeAnzeige),
            _ => ChargeSortAscending ? ChargenRows.OrderBy(x => x.Charge) : ChargenRows.OrderByDescending(x => x.Charge)
        };

        ChargenRows = sorted.ToList();
    }

    private MarkupString GetSortIcon(string column)
    {
        if (SortColumn != column) return (MarkupString)"<i class=\"fa-solid fa-sort ms-1 text-secondary\"></i>";
        return SortAscending
            ? (MarkupString)"<i class=\"fa-solid fa-sort-up ms-1 text-info\"></i>"
            : (MarkupString)"<i class=\"fa-solid fa-sort-down ms-1 text-info\"></i>";
    }

    private MarkupString GetChargeSortIcon(string column)
    {
        if (ChargeSortColumn != column) return (MarkupString)"<i class=\"fa-solid fa-sort ms-1 text-secondary\"></i>";
        return ChargeSortAscending
            ? (MarkupString)"<i class=\"fa-solid fa-sort-up ms-1 text-info\"></i>"
            : (MarkupString)"<i class=\"fa-solid fa-sort-down ms-1 text-info\"></i>";
    }

    private static int ParseInt(string? value) => int.TryParse(value, out var parsed) ? parsed : 0;

    private static DateTime ParseDate(string? value)
    {
        if (TryParseWareneingangDate(value, out var parsed))
        {
            return parsed;
        }

        return DateTime.MinValue;
    }

    private static bool HasValidDate(string? value) => TryParseWareneingangDate(value, out _);

    private static bool TryParseWareneingangDate(string? value, out DateTime parsed)
    {
        parsed = DateTime.MinValue;

        if (string.IsNullOrWhiteSpace(value))
        {
            return false;
        }

        var text = value.Trim();
        string[] formats =
        {
            "MM/dd/yyyy HH:mm:ss",
            "M/d/yyyy HH:mm:ss",
            "MM/dd/yyyy HH:mm",
            "M/d/yyyy HH:mm",
            "MM/dd/yyyy",
            "M/d/yyyy",
            "dd.MM.yyyy HH:mm:ss",
            "d.M.yyyy HH:mm:ss",
            "dd.MM.yyyy HH:mm",
            "d.M.yyyy HH:mm",
            "dd.MM.yyyy",
            "d.M.yyyy",
            "yyyy-MM-dd HH:mm:ss",
            "yyyy-MM-dd HH:mm",
            "yyyy-MM-dd"
        };

        return DateTime.TryParseExact(
                   text,
                   formats,
                   System.Globalization.CultureInfo.InvariantCulture,
                   System.Globalization.DateTimeStyles.AllowWhiteSpaces,
                   out parsed)
               || DateTime.TryParseExact(
                   text,
                   formats,
                   new System.Globalization.CultureInfo("en-US"),
                   System.Globalization.DateTimeStyles.AllowWhiteSpaces,
                   out parsed)
               || DateTime.TryParseExact(
                   text,
                   formats,
                   new System.Globalization.CultureInfo("de-DE"),
                   System.Globalization.DateTimeStyles.AllowWhiteSpaces,
                   out parsed);
    }
}

