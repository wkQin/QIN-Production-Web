@using System.Globalization
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject SchichtplanService SchichtplanService

<section id="@shellId" class="@($"shiftplan-shell {(isFullscreen ? "is-fullscreen" : string.Empty)}")">
    @if (isLoading)
    {
        <div class="d-flex align-items-center justify-content-center py-5 text-secondary">
            <div class="spinner-border spinner-border-sm text-info me-3" role="status"></div>
            <span>Schichtplan wird geladen...</span>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(loadError))
    {
        <div class="alert alert-danger mb-0" role="alert">
            @loadError
        </div>
    }
    else
    {
        @if (!isFullscreen)
        {
            <div id="@controlsId" class="shiftplan-controls shiftplan-controls-minimal">
                <div class="shiftplan-head-actions shiftplan-head-actions-solo">
                    <button type="button" class="shiftplan-action-btn" @onclick="ToggleFullscreenAsync">
                        <i class="fa-solid fa-expand me-2"></i>
                        Monitoransicht
                    </button>
                </div>
            </div>
        }
        else
        {
            <button type="button" class="shiftplan-fullscreen-exit" aria-label="Monitoransicht verlassen" @onclick="CloseFullscreenAsync">
                <i class="fa-solid fa-xmark"></i>
            </button>
        }

        <div id="@stageShellId" class="shiftplan-stage-shell">
            <div id="@stageId" class="@($"shiftplan-stage {(isFullscreen ? "is-monitor-stage" : "is-embedded-stage")}")">
                <div class="shiftplan-board-meta">
                    <div class="shiftplan-board-copy">
                        <span class="shiftplan-board-kicker">Schichtplan Produktion</span>
                        <strong>KW @calendarWeekLabel</strong>
                    </div>

                    <div class="shiftplan-board-status">
                        <span>@boardDateLabel</span>
                        <span>Zuletzt aktualisiert: @lastUpdatedLabel</span>
                    </div>
                </div>

                <section class="shiftplan-table-panel">
                    <div class="shiftplan-table-grid shiftplan-header-row">
                        <div class="shiftplan-cell shiftplan-header-cell shiftplan-header-machine">
                            <span>Maschine / Arbeitsplatz</span>
                            <small>Nummer und Planung</small>
                        </div>

                        @for (var shiftIndex = 0; shiftIndex < shiftHeaders.Length; shiftIndex++)
                        {
                            <div class="@($"shiftplan-cell shiftplan-header-cell {shiftHeaders[shiftIndex].ColumnClass}")">
                                <span>@shiftHeaders[shiftIndex].Label</span>
                                <small>Material, Mitarbeiter, Notiz</small>
                            </div>
                        }
                    </div>

                    @foreach (var group in board.Sections)
                    {
                        <div class="@($"shiftplan-row shiftplan-group-row {group.ThemeClass}")">
                            <div class="shiftplan-group-content">
                                <strong>@group.Name</strong>
                                <span>@group.Workplaces.Count Arbeitsplätze</span>
                            </div>
                        </div>

                        @for (var machineIndex = 0; machineIndex < group.Workplaces.Count; machineIndex++)
                        {
                            var machine = group.Workplaces[machineIndex];

                            <div class="@($"shiftplan-row shiftplan-data-row {group.ThemeClass} {(machineIndex % 2 == 1 ? "is-alt" : string.Empty)}")">
                                <div class="shiftplan-cell shiftplan-machine-cell">
                                    <div class="shiftplan-machine-meta">
                                        <span class="shiftplan-machine-number">@GetWorkplaceNumber(machine.ArbeitsplatzNr)</span>
                                        <span class="shiftplan-machine-staffing">Arbeitsplatz</span>
                                    </div>
                                    <strong class="shiftplan-machine-name">@machine.ArbeitsplatzName</strong>
                                </div>

                                @for (var shiftIndex = 0; shiftIndex < machine.Shifts.Count; shiftIndex++)
                                {
                                    var cell = machine.Shifts[shiftIndex];
                                    var columnClass = shiftHeaders[shiftIndex].ColumnClass;

                                    <div class="@($"shiftplan-cell shiftplan-shift-cell {columnClass}")">
                                        @if (!cell.HasContent)
                                        {
                                            <div class="shiftplan-empty-cell">frei</div>
                                        }
                                        else
                                        {
                                            <article class="@($"shiftplan-task {columnClass}")">
                                                <div class="shiftplan-task-head">
                                                    <div class="shiftplan-task-material">@GetMaterialLabel(cell.Material)</div>
                                                    <span class="shiftplan-task-count">@GetPeopleCountLabel(cell.AssignedUsers.Count)</span>
                                                </div>

                                                @if (!string.IsNullOrWhiteSpace(cell.FANr))
                                                {
                                                    <div class="shiftplan-task-meta">
                                                        <span>FA-Nr</span>
                                                        <strong>@cell.FANr</strong>
                                                    </div>
                                                }

                                                @if (cell.AssignedUsers.Count > 0)
                                                {
                                                    <div class="shiftplan-task-people-grid">
                                                        @foreach (var person in cell.AssignedUsers)
                                                        {
                                                            <span class="shiftplan-task-person">@person.DisplayName</span>
                                                        }
                                                    </div>
                                                }

                                                @if (!string.IsNullOrWhiteSpace(cell.Bemerkung))
                                                {
                                                    <div class="shiftplan-task-note">@cell.Bemerkung</div>
                                                }
                                            </article>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                </section>
            </div>
        </div>
    }
</section>

@code {
    [Parameter] public DateTime? PlanDate { get; set; }

    private readonly string shellId = $"shiftplan-shell-{Guid.NewGuid():N}";
    private readonly string controlsId = $"shiftplan-controls-{Guid.NewGuid():N}";
    private readonly string stageShellId = $"shiftplan-stage-shell-{Guid.NewGuid():N}";
    private readonly string stageId = $"shiftplan-stage-{Guid.NewGuid():N}";

    private readonly ShiftHeader[] shiftHeaders =
    [
        new(SchichtplanKonstanten.Nachtschicht, "shift-night"),
        new(SchichtplanKonstanten.Frühschicht, "shift-early"),
        new(SchichtplanKonstanten.Spätschicht, "shift-late")
    ];

    private SchichtplanBoardModel board = new()
    {
        PlanDatum = DateTime.Today,
        Kalenderwoche = SchichtplanKonstanten.Kalenderwoche(DateTime.Today)
    };

    private DateTime? lastLoadedDate;
    private bool isLoading = true;
    private string? loadError;
    private bool isFullscreen;
    private bool activateMonitorView;

    private string boardDateLabel =>
        board.PlanDatum.ToString("dddd, dd.MM.yyyy", CultureInfo.GetCultureInfo("de-DE"));

    private string calendarWeekLabel =>
        board.Kalenderwoche.ToString("00", CultureInfo.InvariantCulture);

    private string lastUpdatedLabel =>
        board.LastUpdatedAt.HasValue
            ? board.LastUpdatedAt.Value.ToString("dd.MM.yyyy HH:mm", CultureInfo.GetCultureInfo("de-DE")) + " Uhr"
            : "Noch nicht geändert";

    protected override async Task OnParametersSetAsync()
    {
        var requestedDate = (PlanDate ?? DateTime.Today).Date;
        if (lastLoadedDate != requestedDate || !string.IsNullOrWhiteSpace(loadError))
        {
            await LoadBoardAsync(requestedDate);
        }
    }

    private async Task LoadBoardAsync(DateTime requestedDate)
    {
        isLoading = true;
        loadError = null;

        try
        {
            board = await SchichtplanService.GetBoardAsync(requestedDate);
            lastLoadedDate = requestedDate;
        }
        catch (Exception ex)
        {
            board = new SchichtplanBoardModel
            {
                PlanDatum = requestedDate,
                Kalenderwoche = SchichtplanKonstanten.Kalenderwoche(requestedDate)
            };
            loadError = ex.Message;
        }
        finally
        {
            isLoading = false;
            if (isFullscreen)
            {
                activateMonitorView = true;
            }
        }
    }

    private async Task ToggleFullscreenAsync()
    {
        if (isFullscreen)
        {
            await CloseFullscreenAsync();
            return;
        }

        isFullscreen = true;
        activateMonitorView = true;
    }

    private async Task CloseFullscreenAsync()
    {
        if (isFullscreen)
        {
            await JS.InvokeVoidAsync("shiftPlanBoard.deactivate", shellId, stageShellId, stageId);
        }

        isFullscreen = false;
        activateMonitorView = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!activateMonitorView)
        {
            return;
        }

        activateMonitorView = false;
        await JS.InvokeVoidAsync("shiftPlanBoard.activate", shellId, controlsId, stageShellId, stageId);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("shiftPlanBoard.deactivate", shellId, stageShellId, stageId);
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private static string GetPeopleCountLabel(int count) => count switch
    {
        0 => "offen",
        1 => "1 Person",
        _ => $"{count} Personen"
    };

    private static string GetMaterialLabel(string? material) =>
        string.IsNullOrWhiteSpace(material) ? "Noch kein Material" : material;

    private static string GetWorkplaceNumber(string? workplaceNumber) =>
        string.IsNullOrWhiteSpace(workplaceNumber) ? "Sonderplatz" : workplaceNumber;

    private sealed record ShiftHeader(string Label, string ColumnClass);
}
