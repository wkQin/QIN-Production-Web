    private static ShiftPlanMachine Machine(
        string number,
        string name,
        string staffing,
        ShiftPlanSlot? night = null,
        ShiftPlanSlot? early = null,
        ShiftPlanSlot? late = null)
        => new(number, name, staffing, night, early, late);

    private static ShiftPlanSlot Slot(string material, string[] people, string? note = null)
        => new(material, people, note);

    private static string GetPeopleCountLabel(int count)
        => count == 1 ? "1 Person" : $"{count} Personen";

    private sealed record ShiftHeader(string Label, string ColumnClass);

    private sealed record ShiftPlanSlot(string Material, string[] People, string? Note);

    private sealed record ShiftPlanMachine(
        string Number,
        string Name,
        string Staffing,
        ShiftPlanSlot? Night,
        ShiftPlanSlot? Early,
        ShiftPlanSlot? Late)
    {
        public IReadOnlyList<ShiftPlanSlot?> Shifts => [Night, Early, Late];
    }

    private sealed record ShiftPlanSection(
