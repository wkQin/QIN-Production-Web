@using System.Globalization
@using System.Threading
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject SchichtplanService SchichtplanService

<section id="@shellId" class="@($"shiftplan-shell {(isFullscreen ? "is-fullscreen" : string.Empty)}")">
    @if (isLoading)
    {
        <div class="d-flex align-items-center justify-content-center py-5 text-secondary">
            <div class="spinner-border spinner-border-sm text-info me-3" role="status"></div>
            <span>Schichtplan wird geladen...</span>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(loadError))
    {
        <div class="alert alert-danger mb-0" role="alert">
            @loadError
        </div>
    }
    else
    {
        @if (!isFullscreen)
        {
            <div id="@controlsId" class="shiftplan-controls shiftplan-controls-minimal">
                <div class="shiftplan-head-actions shiftplan-head-actions-solo">
                    <button type="button" class="shiftplan-action-btn" @onclick="ToggleFullscreenAsync">
                        <i class="fa-solid fa-expand me-2"></i>
                        Monitoransicht
                    </button>
                </div>
            </div>
        }
        else
        {
            <button type="button" class="shiftplan-fullscreen-exit" aria-label="Monitoransicht verlassen" @onclick="CloseFullscreenAsync">
                <i class="fa-solid fa-xmark"></i>
            </button>
        }

        <div id="@stageShellId" class="shiftplan-stage-shell">
            <div id="@stageId" class="@($"shiftplan-stage {(isFullscreen ? "is-monitor-stage" : "is-embedded-stage")}")">
                <div class="shiftplan-board-meta">
                    <div class="shiftplan-board-copy">
                        <span class="shiftplan-board-kicker">Schichtplan Produktion</span>
                        <strong>KW @calendarWeekLabel</strong>
                    </div>

                    <div class="shiftplan-date-control" aria-label="Plan-Datum">
                        <button type="button"
                                class="shiftplan-date-step"
                                title="Vortag anzeigen"
                                aria-label="Vortag anzeigen"
                                @onclick="ShowPreviousDayAsync">
                            <i class="fa-solid fa-chevron-left"></i>
                        </button>

                        <label class="shiftplan-date-picker">
                            <i class="fa-solid fa-calendar-days" aria-hidden="true"></i>
                            <span class="shiftplan-date-label">@boardDateLabel</span>
                            <input type="date"
                                   class="shiftplan-date-input"
                                   value="@selectedDateInputValue"
                                   aria-label="Plan-Datum auswaehlen"
                                   @onchange="OnBoardDateChangedAsync" />
                        </label>

                        <button type="button"
                                class="shiftplan-date-step"
                                title="Naechsten Tag anzeigen"
                                aria-label="Naechsten Tag anzeigen"
                                @onclick="ShowNextDayAsync">
                            <i class="fa-solid fa-chevron-right"></i>
                        </button>

                        <button type="button"
                                class="shiftplan-today-btn"
                                disabled="@isTodayButtonDisabled"
                                @onclick="SelectTodayAsync">
                            Heute
                        </button>
                    </div>

                    <div class="shiftplan-board-status">
                        <span>Zuletzt aktualisiert: @lastUpdatedLabel</span>
                    </div>
                </div>

                <section class="shiftplan-table-panel">
                    <div class="shiftplan-table-grid shiftplan-header-row">
                        <div class="shiftplan-cell shiftplan-header-cell shiftplan-header-machine">
                            <span>Maschine / Arbeitsplatz</span>
                            <small>Nummer und Planung</small>
                        </div>

                        @foreach (var shiftHeader in shiftHeaders)
                        {
                            <div class="shiftplan-cell shiftplan-header-cell">
                                <span>@shiftHeader.Label</span>
                                <small>Materialien, Mitarbeiter, Notiz</small>
                            </div>
                        }
                    </div>

                    @if (VisibleSections.Count == 0)
                    {
                        <div class="shiftplan-empty-board">Noch keine belegten Arbeitsplätze vorhanden.</div>
                    }
                    else
                    {
                        @foreach (var group in VisibleSections)
                        {
                            <div class="@($"shiftplan-row shiftplan-group-row {group.ThemeClass}")">
                                <div class="shiftplan-group-content">
                                    <strong>@group.Name</strong>
                                    <span>@group.Workplaces.Count Arbeitsplätze</span>
                                </div>
                            </div>

                            @for (var machineIndex = 0; machineIndex < group.Workplaces.Count; machineIndex++)
                            {
                                var machine = group.Workplaces[machineIndex];

                                <div class="@($"shiftplan-row shiftplan-data-row {group.ThemeClass} {(machineIndex % 2 == 1 ? "is-alt" : string.Empty)}")">
                                    <div class="shiftplan-cell shiftplan-machine-cell">
                                        <div class="shiftplan-machine-meta">
                                            <span class="shiftplan-machine-number">@GetWorkplaceNumber(machine.ArbeitsplatzNr)</span>
                                            <span class="shiftplan-machine-staffing">Arbeitsplatz</span>
                                        </div>
                                        <strong class="shiftplan-machine-name">@machine.ArbeitsplatzName</strong>
                                    </div>

                                    @foreach (var cell in machine.Shifts)
                                    {
                                        <div class="shiftplan-cell shiftplan-shift-cell">
                                            @if (!cell.HasContent)
                                            {
                                                <div class="shiftplan-empty-cell">frei</div>
                                            }
                                            else
                                            {
                                                <article class="@($"shiftplan-task {group.ThemeClass}")">
                                                    <div class="shiftplan-task-head">
                                                        <div class="shiftplan-task-material-stack">
                                                            @if (cell.Materials.Count == 0)
                                                            {
                                                                <div class="shiftplan-task-material">Noch kein Material</div>
                                                            }
                                                            else
                                                            {
                                                                @foreach (var material in cell.Materials)
                                                                {
                                                                    <div class="shiftplan-task-material">@material.Material</div>
                                                                }
                                                            }
                                                        </div>
                                                        <span class="shiftplan-task-count">@GetPeopleCountLabel(cell.AssignedUsers.Count)</span>
                                                    </div>

                                                    @if (!string.IsNullOrWhiteSpace(cell.FANr))
                                                    {
                                                        <div class="shiftplan-task-meta">
                                                            <span>FA-Nr</span>
                                                            <strong>@cell.FANr</strong>
                                                        </div>
                                                    }

                                                    @if (cell.AssignedUsers.Count > 0)
                                                    {
                                                        <div class="shiftplan-task-people-grid">
                                                            @foreach (var person in cell.AssignedUsers)
                                                            {
                                                                <span class="shiftplan-task-person">@person.DisplayName</span>
                                                            }
                                                        </div>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(cell.Bemerkung))
                                                    {
                                                        <div class="shiftplan-task-note">@cell.Bemerkung</div>
                                                    }
                                                </article>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        }
                    }
                </section>
            </div>
        </div>
    }
</section>

@code {
    [Parameter] public DateTime? PlanDate { get; set; }

    private readonly string shellId = $"shiftplan-shell-{Guid.NewGuid():N}";
    private readonly string controlsId = $"shiftplan-controls-{Guid.NewGuid():N}";
    private readonly string stageShellId = $"shiftplan-stage-shell-{Guid.NewGuid():N}";
    private readonly string stageId = $"shiftplan-stage-{Guid.NewGuid():N}";

    private readonly ShiftHeader[] shiftHeaders =
    [
        new(SchichtplanKonstanten.Nachtschicht),
        new(SchichtplanKonstanten.Frühschicht),
        new(SchichtplanKonstanten.Spätschicht)
    ];
    private static readonly TimeSpan MonitorAutoRefreshInterval = TimeSpan.FromSeconds(60);

    private SchichtplanBoardModel board = new()
    {
        PlanDatum = DateTime.Today,
        Kalenderwoche = SchichtplanKonstanten.Kalenderwoche(DateTime.Today)
    };

    private DateTime? lastLoadedDate;
    private DateTime selectedBoardDate = DateTime.Today;
    private DateTime? previousPlanDateParameter;
    private bool hasManualDateSelection;
    private bool isLoading = true;
    private string? loadError;
    private bool isFullscreen;
    private bool activateMonitorView;
    private bool isBackgroundRefreshing;
    private CancellationTokenSource? monitorRefreshCts;

    private string boardDateLabel =>
        board.PlanDatum.ToString("dddd, dd.MM.yyyy", CultureInfo.GetCultureInfo("de-DE"));

    private string selectedDateInputValue =>
        selectedBoardDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);

    private bool isTodaySelected =>
        selectedBoardDate.Date == DateTime.Today;

    private bool isTodayButtonDisabled =>
        isTodaySelected && !hasManualDateSelection;

    private string calendarWeekLabel =>
        board.Kalenderwoche.ToString("00", CultureInfo.InvariantCulture);

    private string lastUpdatedLabel =>
        board.LastUpdatedAt.HasValue
            ? board.LastUpdatedAt.Value.ToString("dd.MM.yyyy HH:mm", CultureInfo.GetCultureInfo("de-DE")) + " Uhr"
            : "Noch nicht geändert";

    private List<SchichtplanSectionModel> VisibleSections =>
        board.Sections
            .Select(section => new SchichtplanSectionModel
            {
                Name = section.Name,
                ThemeClass = section.ThemeClass,
                Sortierung = section.Sortierung,
                Workplaces = section.Workplaces
                    .Where(HasAssignedUsers)
                    .ToList()
            })
            .Where(section => section.Workplaces.Count > 0)
            .ToList();

    private DateTime ResolveRequestedDate() =>
        PlanDate.HasValue || hasManualDateSelection
            ? selectedBoardDate.Date
            : DateTime.Today;

    protected override async Task OnParametersSetAsync()
    {
        var parameterDate = PlanDate?.Date;
        if (parameterDate.HasValue && previousPlanDateParameter != parameterDate)
        {
            selectedBoardDate = parameterDate.Value;
            hasManualDateSelection = false;
        }
        else if (!parameterDate.HasValue && !hasManualDateSelection)
        {
            selectedBoardDate = DateTime.Today;
        }

        previousPlanDateParameter = parameterDate;

        var requestedDate = ResolveRequestedDate();
        if (lastLoadedDate != requestedDate || !string.IsNullOrWhiteSpace(loadError))
        {
            await LoadBoardAsync(requestedDate);
        }
    }

    private async Task LoadBoardAsync(DateTime requestedDate, bool showLoadingState = true)
    {
        selectedBoardDate = requestedDate.Date;

        if (showLoadingState)
        {
            isLoading = true;
            loadError = null;
        }

        try
        {
            board = await SchichtplanService.GetBoardAsync(requestedDate);
            lastLoadedDate = requestedDate;
            loadError = null;
        }
        catch (Exception ex)
        {
            if (showLoadingState || lastLoadedDate is null)
            {
                board = new SchichtplanBoardModel
                {
                    PlanDatum = requestedDate,
                    Kalenderwoche = SchichtplanKonstanten.Kalenderwoche(requestedDate)
                };
                loadError = ex.Message;
            }
        }
        finally
        {
            if (showLoadingState)
            {
                isLoading = false;
            }

            if (isFullscreen)
            {
                activateMonitorView = true;
            }
        }
    }

    private async Task OnBoardDateChangedAsync(ChangeEventArgs args)
    {
        if (DateTime.TryParseExact(
            args.Value?.ToString(),
            "yyyy-MM-dd",
            CultureInfo.InvariantCulture,
            DateTimeStyles.None,
            out var parsedDate))
        {
            await SelectBoardDateAsync(parsedDate, true);
        }
    }

    private Task ShowPreviousDayAsync() =>
        SelectBoardDateAsync(selectedBoardDate.AddDays(-1), true);

    private Task ShowNextDayAsync() =>
        SelectBoardDateAsync(selectedBoardDate.AddDays(1), true);

    private async Task SelectTodayAsync()
    {
        hasManualDateSelection = false;
        await SelectBoardDateAsync(DateTime.Today, false);
    }

    private async Task SelectBoardDateAsync(DateTime requestedDate, bool markAsManualSelection)
    {
        var date = requestedDate.Date;
        if (markAsManualSelection)
        {
            hasManualDateSelection = true;
        }

        if (selectedBoardDate == date && lastLoadedDate == date && string.IsNullOrWhiteSpace(loadError))
        {
            return;
        }

        await LoadBoardAsync(date);
    }

    private async Task ToggleFullscreenAsync()
    {
        if (isFullscreen)
        {
            await CloseFullscreenAsync();
            return;
        }

        isFullscreen = true;
        activateMonitorView = true;
        StartMonitorAutoRefresh();
    }

    private async Task CloseFullscreenAsync()
    {
        StopMonitorAutoRefresh();

        if (isFullscreen)
        {
            await JS.InvokeVoidAsync("shiftPlanBoard.deactivate", shellId, stageShellId, stageId);
        }

        isFullscreen = false;
        activateMonitorView = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!activateMonitorView)
        {
            return;
        }

        activateMonitorView = false;
        await JS.InvokeVoidAsync("shiftPlanBoard.activate", shellId, controlsId, stageShellId, stageId);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            StopMonitorAutoRefresh();
            await JS.InvokeVoidAsync("shiftPlanBoard.deactivate", shellId, stageShellId, stageId);
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private void StartMonitorAutoRefresh()
    {
        StopMonitorAutoRefresh();
        monitorRefreshCts = new CancellationTokenSource();
        _ = RunMonitorAutoRefreshAsync(monitorRefreshCts.Token);
    }

    private void StopMonitorAutoRefresh()
    {
        if (monitorRefreshCts is null)
        {
            return;
        }

        monitorRefreshCts.Cancel();
        monitorRefreshCts.Dispose();
        monitorRefreshCts = null;
    }

    private async Task RunMonitorAutoRefreshAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(MonitorAutoRefreshInterval);

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(async () =>
                {
                    if (!isFullscreen || isLoading || isBackgroundRefreshing)
                    {
                        return;
                    }

                    isBackgroundRefreshing = true;

                    try
                    {
                        await LoadBoardAsync(ResolveRequestedDate(), showLoadingState: false);
                        StateHasChanged();
                    }
                    finally
                    {
                        isBackgroundRefreshing = false;
                    }
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private static string GetPeopleCountLabel(int count) => count switch
    {
        0 => "offen",
        1 => "1 Person",
        _ => $"{count} Personen"
    };

    private static string GetWorkplaceNumber(string? workplaceNumber) =>
        string.IsNullOrWhiteSpace(workplaceNumber) ? "Sonderplatz" : workplaceNumber;

    private static bool HasAssignedUsers(SchichtplanWorkplaceModel workplace) =>
        workplace.Shifts.Any(cell => cell.AssignedUsers.Count > 0);

    private sealed record ShiftHeader(string Label);
}
